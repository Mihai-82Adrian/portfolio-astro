---
import BaseLayout from '@/layouts/BaseLayout.astro';
import {
  Bot,
  Calculator,
  CheckCircle2,
  Code2,
  Cog,
  LineChart,
  Mail,
  MessageSquare,
  Rocket
} from '@lucide/astro';
import { generateBreadcrumbSchema } from '@utils/structuredData';

const title = 'CFO meets CTO — Services für DACH';
const description =
  'CFO trifft CTO für die DACH-Region: Buchhaltungsautomatisierung, Lohnabrechnung und KI-gestützte Webentwicklung für Gründer. Finance Ops ab €900/Monat.';

const breadcrumbSchema = generateBreadcrumbSchema([
  { name: 'Home', url: 'https://me-mateescu.de/' },
  { name: 'Services', url: 'https://me-mateescu.de/services' }
]);
---

<BaseLayout title={title} description={description} lang="de" structuredData={breadcrumbSchema}>
  <main class="pb-20">
    <section class="mx-auto w-full max-w-6xl px-4 pt-20 md:px-6 md:pt-24">
      <div class="mx-auto max-w-3xl text-center">
        <p class="mb-4 inline-flex items-center rounded-full border border-black/10 bg-[var(--bg-elevated)] px-4 py-1.5 text-xs font-semibold tracking-wide text-eucalyptus-700 dark:border-white/15 dark:text-eucalyptus-300">
          Services
        </p>
        <h1 class="text-balance text-4xl font-bold leading-tight text-text-primary-light dark:text-text-primary-dark sm:text-5xl">
          CFO meets CTO für die DACH-Region
        </h1>
        <p class="mt-4 text-pretty text-base text-text-secondary-light dark:text-text-secondary-dark sm:text-lg">
          Finance Ops & AI-Powered Web Engineering. Höchste Qualität durch effiziente KI-Orchestrierung.
        </p>
      </div>
    </section>

    <section class="mx-auto mt-12 w-full max-w-6xl px-4 md:px-6">
      <div class="mb-4">
        <h2 class="text-xl font-semibold text-text-primary-light dark:text-text-primary-dark">CFO Pillar · Finance Ops & Strategy</h2>
      </div>

      <div class="grid grid-cols-1 gap-6 lg:grid-cols-12">
        <article class="group rounded-2xl border border-black/10 bg-[var(--bg-elevated)] p-6 transition-all duration-300 hover:-translate-y-0.5 hover:border-eucalyptus-500/50 dark:border-white/10 dark:hover:border-eucalyptus-400/50 lg:col-span-7">
          <div class="mb-3 inline-flex h-9 w-9 items-center justify-center rounded-lg border border-black/10 bg-eucalyptus-100 text-eucalyptus-700 dark:border-white/10 dark:bg-eucalyptus-900/35 dark:text-eucalyptus-300">
            <Calculator class="h-5 w-5" aria-hidden="true" />
          </div>
          <h3 class="text-balance text-xl font-semibold text-text-primary-light dark:text-text-primary-dark">Finance Ops Core</h3>
          <p class="mt-3 text-lg font-bold text-eucalyptus-400 dark:text-eucalyptus-300">ab 900 € / Monat</p>
          <ul class="mt-4 space-y-3 text-sm leading-relaxed text-text-secondary-light dark:text-text-secondary-dark">
            <li class="flex items-start gap-3">
              <CheckCircle2 class="mt-0.5 h-4 w-4 shrink-0 text-eucalyptus-400" aria-hidden="true" />
              <span>Buchen laufender Geschäftsvorfälle</span>
            </li>
            <li class="flex items-start gap-3">
              <CheckCircle2 class="mt-0.5 h-4 w-4 shrink-0 text-eucalyptus-400" aria-hidden="true" />
              <span>Laufende Lohn- &amp; Gehaltsabrechnung</span>
            </li>
            <li class="flex items-start gap-3">
              <CheckCircle2 class="mt-0.5 h-4 w-4 shrink-0 text-eucalyptus-400" aria-hidden="true" />
              <span>Digitale Beleg-Workflows &amp; Automatisierung</span>
            </li>
          </ul>
          <p class="mt-6 border-t border-black/10 pt-4 text-xs leading-relaxed text-text-muted-light dark:border-white/10 dark:text-text-muted-dark">
            Leistungen nach §6 Nr.4 StBerG. Ausdrücklich keine Steuerberatung, keine Jahresabschlüsse oder EÜR.
          </p>
        </article>

        <article class="group rounded-2xl border border-black/10 bg-[var(--bg-elevated)] p-6 transition-all duration-300 hover:-translate-y-0.5 hover:border-eucalyptus-500/50 dark:border-white/10 dark:hover:border-eucalyptus-400/50 lg:col-span-5">
          <div class="mb-3 inline-flex h-9 w-9 items-center justify-center rounded-lg border border-black/10 bg-eucalyptus-100 text-eucalyptus-700 dark:border-white/10 dark:bg-eucalyptus-900/35 dark:text-eucalyptus-300">
            <LineChart class="h-5 w-5" aria-hidden="true" />
          </div>
          <h3 class="text-balance text-xl font-semibold text-text-primary-light dark:text-text-primary-dark">CFO Cockpit & Controlling</h3>
          <p class="mt-3 text-lg font-bold text-eucalyptus-400 dark:text-eucalyptus-300">ab 1.500 € (Projekt oder Retainer)</p>
          <ul class="mt-4 space-y-3 text-sm leading-relaxed text-text-secondary-light dark:text-text-secondary-dark">
            <li class="flex items-start gap-3">
              <CheckCircle2 class="mt-0.5 h-4 w-4 shrink-0 text-eucalyptus-400" aria-hidden="true" />
              <span>Cashflow-Modellierung &amp; Szenario-Analyse</span>
            </li>
            <li class="flex items-start gap-3">
              <CheckCircle2 class="mt-0.5 h-4 w-4 shrink-0 text-eucalyptus-400" aria-hidden="true" />
              <span>Interaktive KPI-Dashboards</span>
            </li>
            <li class="flex items-start gap-3">
              <CheckCircle2 class="mt-0.5 h-4 w-4 shrink-0 text-eucalyptus-400" aria-hidden="true" />
              <span>Reine betriebswirtschaftliche Beratung</span>
            </li>
          </ul>
        </article>
      </div>
    </section>

    <section class="mx-auto mt-12 w-full max-w-6xl px-4 md:px-6">
      <div class="mb-4">
        <h2 class="text-xl font-semibold text-text-primary-light dark:text-text-primary-dark">CTO Pillar · AI & Web Engineering</h2>
      </div>

      <div class="grid grid-cols-1 gap-6 lg:grid-cols-12">
        <article class="group rounded-2xl border border-black/10 bg-[var(--bg-elevated)] p-6 backdrop-blur-sm transition-all duration-300 hover:-translate-y-0.5 hover:border-eucalyptus-500/60 dark:border-white/10 dark:hover:border-eucalyptus-400/60 lg:col-span-5">
          <div class="mb-3 inline-flex h-9 w-9 items-center justify-center rounded-lg border border-black/10 bg-eucalyptus-100 text-eucalyptus-700 dark:border-white/10 dark:bg-eucalyptus-900/35 dark:text-eucalyptus-300">
            <Code2 class="h-5 w-5" aria-hidden="true" />
          </div>
          <h3 class="text-balance text-xl font-semibold text-text-primary-light dark:text-text-primary-dark">Base Astro Portfolio</h3>
          <p class="mt-3 text-lg font-bold text-eucalyptus-400 dark:text-eucalyptus-300">1.200 € – 1.800 €</p>
          <ul class="mt-4 space-y-3 text-sm leading-relaxed text-text-secondary-light dark:text-text-secondary-dark">
            <li class="flex items-start gap-3">
              <CheckCircle2 class="mt-0.5 h-4 w-4 shrink-0 text-eucalyptus-400" aria-hidden="true" />
              <span>Edge-natives Astro/Tailwind Setup</span>
            </li>
            <li class="flex items-start gap-3">
              <CheckCircle2 class="mt-0.5 h-4 w-4 shrink-0 text-eucalyptus-400" aria-hidden="true" />
              <span>100/100 Lighthouse Performance</span>
            </li>
            <li class="flex items-start gap-3">
              <CheckCircle2 class="mt-0.5 h-4 w-4 shrink-0 text-eucalyptus-400" aria-hidden="true" />
              <span>Maßgeschneidertes Design (keine Templates)</span>
            </li>
          </ul>
        </article>

        <article class="group rounded-2xl border border-black/10 bg-[var(--bg-elevated)] p-6 backdrop-blur-sm transition-all duration-300 hover:-translate-y-0.5 hover:border-eucalyptus-500/60 dark:border-white/10 dark:hover:border-eucalyptus-400/60 lg:col-span-7">
          <div class="mb-3 inline-flex h-9 w-9 items-center justify-center rounded-lg border border-black/10 bg-eucalyptus-100 text-eucalyptus-700 dark:border-white/10 dark:bg-eucalyptus-900/35 dark:text-eucalyptus-300">
            <Bot class="h-5 w-5" aria-hidden="true" />
          </div>
          <h3 class="text-balance text-xl font-semibold text-text-primary-light dark:text-text-primary-dark">Pro AI Hub</h3>
          <p class="mt-3 text-lg font-bold text-eucalyptus-400 dark:text-eucalyptus-300">2.500 € – 3.500 €</p>
          <ul class="mt-4 space-y-3 text-sm leading-relaxed text-text-secondary-light dark:text-text-secondary-dark">
            <li class="flex items-start gap-3">
              <CheckCircle2 class="mt-0.5 h-4 w-4 shrink-0 text-eucalyptus-400" aria-hidden="true" />
              <span>Alles aus dem Base-Paket</span>
            </li>
            <li class="flex items-start gap-3">
              <CheckCircle2 class="mt-0.5 h-4 w-4 shrink-0 text-eucalyptus-400" aria-hidden="true" />
              <span>Integrierter Custom RAG AI Chatbot</span>
            </li>
            <li class="flex items-start gap-3">
              <CheckCircle2 class="mt-0.5 h-4 w-4 shrink-0 text-eucalyptus-400" aria-hidden="true" />
              <span>Proof of Work: Testen Sie "Ask Mihai AI" direkt hier im Menü.</span>
            </li>
          </ul>
        </article>
      </div>
    </section>

    <section class="mx-auto mt-14 w-full max-w-6xl px-4 md:px-6">
      <h2 class="text-2xl font-semibold text-center text-text-primary-light dark:text-text-primary-dark">
        So funktioniert die Zusammenarbeit
      </h2>
      <div class="mt-6 grid grid-cols-1 gap-4 md:grid-cols-3">
        <article class="rounded-2xl border border-black/10 bg-[var(--bg-elevated)] p-5 dark:border-white/10">
          <div class="mb-3 inline-flex h-9 w-9 items-center justify-center rounded-lg border border-black/10 bg-eucalyptus-100 text-eucalyptus-700 dark:border-white/10 dark:bg-eucalyptus-900/35 dark:text-eucalyptus-300">
            <MessageSquare class="h-5 w-5" aria-hidden="true" />
          </div>
          <h3 class="text-base font-semibold text-text-primary-light dark:text-text-primary-dark">
            Erstgespräch (Kostenlos)
          </h3>
          <p class="mt-2 text-sm leading-relaxed text-text-secondary-light dark:text-text-secondary-dark">
            Wir analysieren Ihre aktuelle Situation und prüfen, ob mein Setup zu Ihren Zielen passt.
          </p>
        </article>

        <article class="rounded-2xl border border-black/10 bg-[var(--bg-elevated)] p-5 dark:border-white/10">
          <div class="mb-3 inline-flex h-9 w-9 items-center justify-center rounded-lg border border-black/10 bg-eucalyptus-100 text-eucalyptus-700 dark:border-white/10 dark:bg-eucalyptus-900/35 dark:text-eucalyptus-300">
            <Cog class="h-5 w-5" aria-hidden="true" />
          </div>
          <h3 class="text-base font-semibold text-text-primary-light dark:text-text-primary-dark">
            Strategie &amp; Setup
          </h3>
          <p class="mt-2 text-sm leading-relaxed text-text-secondary-light dark:text-text-secondary-dark">
            Präzise Implementierung der digitalen Workflows oder Architektur Ihres AI-Hubs.
          </p>
        </article>

        <article class="rounded-2xl border border-black/10 bg-[var(--bg-elevated)] p-5 dark:border-white/10">
          <div class="mb-3 inline-flex h-9 w-9 items-center justify-center rounded-lg border border-black/10 bg-eucalyptus-100 text-eucalyptus-700 dark:border-white/10 dark:bg-eucalyptus-900/35 dark:text-eucalyptus-300">
            <Rocket class="h-5 w-5" aria-hidden="true" />
          </div>
          <h3 class="text-base font-semibold text-text-primary-light dark:text-text-primary-dark">
            Live-Gang &amp; Betreuung
          </h3>
          <p class="mt-2 text-sm leading-relaxed text-text-secondary-light dark:text-text-secondary-dark">
            Sie erhalten fundierte Daten für Ihre Entscheidungen oder einen hochkonvertierenden Web-Auftritt.
          </p>
        </article>
      </div>
    </section>

    <section class="mx-auto mt-12 w-full max-w-6xl px-4 md:px-6">
      <div class="rounded-2xl border border-black/10 bg-[var(--bg-elevated)] p-6 md:p-8 dark:border-white/10">
        <p class="text-pretty text-base leading-relaxed text-text-secondary-light dark:text-text-secondary-dark md:text-lg">
          Aufgrund meines Anspruchs auf kompromisslose Qualität und meiner Tätigkeit als Finanzbuchhalter nehme ich maximal 2 neue Projekte pro Monat an.
        </p>
        <a
          href="mailto:mihai.mateescu@web.de"
          class="mt-6 inline-flex items-center justify-center gap-2 rounded-xl bg-eucalyptus-500 px-5 py-3 text-sm font-semibold text-eucalyptus-950 shadow-sm transition-colors duration-200 hover:bg-eucalyptus-400 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-eucalyptus-500/60 focus-visible:ring-offset-2 dark:focus-visible:ring-offset-dark-bg"
        >
          <Mail class="h-4 w-4" aria-hidden="true" />
          Verfügbarkeit anfragen
        </a>
      </div>
    </section>
  </main>
</BaseLayout>
