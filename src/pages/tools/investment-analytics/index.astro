---
import BaseLayout from '@/layouts/BaseLayout.astro';
import InvestmentApp from '@/components/tools/investment-analytics/InvestmentApp.svelte';
import { generateBreadcrumbSchema } from '@utils/structuredData';

const title = 'Investment Analytics — Rendite, Risiko & DACH-Steuer';
const description =
  'Berechnen Sie ROI, CAGR, IRR, NPV, Sharpe Ratio, Max Drawdown und Abgeltungsteuer für Ihre Investition — mit 1.000-Pfade Monte-Carlo-Simulation, lokal im Browser.';

const breadcrumbSchema = generateBreadcrumbSchema([
  { name: 'Home', url: '/' },
  { name: 'Tools', url: '/tools' },
  { name: 'Investment Analytics', url: '/tools/investment-analytics' },
]);
---

<BaseLayout title={title} description={description} lang="de" ogImage="/images/tools/og-investment-analytics.webp" structuredData={breadcrumbSchema}>
  <main class="pb-20">
    <section class="mx-auto w-full max-w-6xl px-4 pt-20 md:px-6 md:pt-24">
      <div class="mx-auto max-w-3xl text-center">
        <p class="mb-4 inline-flex items-center rounded-full border border-black/10 bg-[var(--bg-elevated)] px-4 py-1.5 text-xs font-semibold tracking-wide text-eucalyptus-700 dark:border-white/15 dark:text-eucalyptus-300">
          Fin-Tools Hub — Investment Analytics
        </p>
        <h1 class="text-balance text-3xl font-bold text-text-primary-light dark:text-text-primary-dark sm:text-4xl">
          Investment Analytics
        </h1>
        <p class="mt-3 text-pretty text-base text-text-secondary-light dark:text-text-secondary-dark sm:text-lg">
          Rendite- und Risikokennzahlen, Monte-Carlo-Simulation und DACH-Steuerberechnung
          für Ihre Investition — vollständig lokal im Browser.
        </p>
        <p class="mx-auto mt-4 max-w-2xl text-xs text-text-muted-light dark:text-text-muted-dark">
          Alle Berechnungen erfolgen lokal in Ihrem Browser. Kein Datentransfer, keine Konten.
          Die optionale KI-Analyse ist auf 1× pro Woche limitiert. Für tiefergehende Analysen steht ein
          <a
            href="/services"
            class="font-medium text-eucalyptus-700 underline underline-offset-2 hover:text-eucalyptus-600 dark:text-eucalyptus-300"
          >
            1:1 Strategiegespräch
          </a>
          zur Verfügung.
        </p>
      </div>
    </section>

    <section class="mx-auto mt-10 w-full max-w-6xl px-4 md:px-6">
      <InvestmentApp client:visible />
    </section>
  </main>
</BaseLayout>
