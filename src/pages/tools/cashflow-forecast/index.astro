---
import BaseLayout from '@/layouts/BaseLayout.astro';
import CashflowApp from '@/components/tools/cashflow-forecast/CashflowApp.svelte';
import { generateBreadcrumbSchema } from '@utils/structuredData';

const title = 'Cashflow & Forecasting — 12-Monats-Liquiditätsplanung';
const description =
  'Interaktiver Cashflow-Planer: Einnahmen, Fixkosten und variable Posten in Echtzeit visualisieren — mit KI-Stresstest für Zahlungsverzug, Churn und Kostenschock.';

const breadcrumbSchema = generateBreadcrumbSchema([
  { name: 'Home', url: '/' },
  { name: 'Tools', url: '/tools' },
  { name: 'Cashflow & Forecasting', url: '/tools/cashflow-forecast' },
]);
---

<BaseLayout title={title} description={description} lang="de" ogImage="/images/tools/og-cashflow-forecast.webp" structuredData={breadcrumbSchema}>
  <main class="pb-20">
    <section class="mx-auto w-full max-w-6xl px-4 pt-20 md:px-6 md:pt-24">
      <div class="mx-auto max-w-3xl text-center">
        <p class="mb-4 inline-flex items-center rounded-full border border-black/10 bg-[var(--bg-elevated)] px-4 py-1.5 text-xs font-semibold tracking-wide text-eucalyptus-700 dark:border-white/15 dark:text-eucalyptus-300">
          Fin-Tools Hub — Cashflow & Forecasting
        </p>
        <h1 class="text-balance text-3xl font-bold text-text-primary-light dark:text-text-primary-dark sm:text-4xl">
          Cashflow & Forecasting
        </h1>
        <p class="mt-3 text-pretty text-base text-text-secondary-light dark:text-text-secondary-dark sm:text-lg">
          Modellieren Sie Ihre 12-Monats-Liquidität mit Einnahmen, Fixkosten und variablen Posten —
          der KI-Stresstest simuliert drei kritische Krisenszenarien auf Ihrem Modell.
        </p>
        <p class="mx-auto mt-4 max-w-2xl text-xs text-text-muted-light dark:text-text-muted-dark">
          Alle Daten bleiben lokal in Ihrem Browser. Der KI-Stresstest ist auf 1 Analyse pro Woche
          limitiert. Für tiefergehende Szenario-Analysen steht ein
          <a
            href="/services"
            class="font-medium text-eucalyptus-700 underline underline-offset-2 hover:text-eucalyptus-600 dark:text-eucalyptus-300"
          >
            1:1 Strategiegespräch
          </a>
          zur Verfügung.
        </p>
      </div>
    </section>

    <section class="mx-auto mt-10 w-full max-w-6xl px-4 md:px-6">
      <CashflowApp client:visible />
    </section>
  </main>
</BaseLayout>
