---
import BaseLayout from '@/layouts/BaseLayout.astro';
import SalaryTaxApp from '@/components/tools/salary-tax/SalaryTaxApp.svelte';
import { generateBreadcrumbSchema } from '@utils/structuredData';

const title = 'Brutto-Netto-Rechner 2026 (BMF PAP)';
const description =
  'Brutto-Netto-Rechner 2026 nach BMF Programmablaufplan: Lohnsteuer, AN+AG-Sozialabgaben, Steuerkeil-Visualisierung, GKV-Kassenvergleich — direkt im Browser.';

const breadcrumbSchema = generateBreadcrumbSchema([
  { name: 'Home', url: 'https://me-mateescu.de/' },
  { name: 'Tools', url: 'https://me-mateescu.de/tools' },
  { name: 'Brutto-Netto-Rechner 2026', url: 'https://me-mateescu.de/tools/salary-tax' },
]);
---

<BaseLayout title={title} description={description} lang="de" structuredData={breadcrumbSchema}>
  <main class="pb-20">
    <section class="mx-auto w-full max-w-6xl px-4 pt-20 md:px-6 md:pt-24">
      <div class="mx-auto max-w-3xl text-center">
        <p class="mb-4 inline-flex items-center rounded-full border border-black/10 bg-[var(--bg-elevated)] px-4 py-1.5 text-xs font-semibold tracking-wide text-eucalyptus-700 dark:border-white/15 dark:text-eucalyptus-300">
          Fin-Tools Hub — Lohnsteuer & Sozialabgaben
        </p>
        <h1 class="text-balance text-3xl font-bold text-text-primary-light dark:text-text-primary-dark sm:text-4xl">
          Brutto-Netto-Rechner 2026
        </h1>
        <p class="mt-3 text-pretty text-base text-text-secondary-light dark:text-text-secondary-dark sm:text-lg">
          Lohnsteuer nach offiziellem BMF Programmablaufplan · Alle Sozialabgaben AN &amp; AG ·
          Steuerkeil-Visualisierung · KV-Kassenvergleich — direkt im Browser, keine Serverübertragung.
        </p>
      </div>
    </section>

    <section class="mx-auto mt-10 w-full max-w-6xl px-4 md:px-6">
      <SalaryTaxApp client:visible />
    </section>
  </main>
</BaseLayout>
