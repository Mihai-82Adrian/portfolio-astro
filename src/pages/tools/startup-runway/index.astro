---
import BaseLayout from '@/layouts/BaseLayout.astro';
import RunwayApp from '@/components/tools/runway/RunwayApp.svelte';
import { generateBreadcrumbSchema } from '@utils/structuredData';

const title = 'Startup Runway & Burn Rate Rechner';
const description =
  'CFO-grade Runway-Rechner für DACH-Startups: Headcount-gesteuerter Burn, MRR-Wachstum, Kapitalinjektionen, Death-Valley-Visualisierung — lokal im Browser.';

const breadcrumbSchema = generateBreadcrumbSchema([
  { name: 'Home', url: 'https://me-mateescu.de/' },
  { name: 'Tools', url: 'https://me-mateescu.de/tools' },
  { name: 'Startup Runway & Burn Rate', url: 'https://me-mateescu.de/tools/startup-runway' },
]);
---

<BaseLayout title={title} description={description} lang="de" ogImage="/images/tools/og-startup-runway.webp" structuredData={breadcrumbSchema}>
  <main class="pb-20">
    <section class="mx-auto w-full max-w-6xl px-4 pt-20 md:px-6 md:pt-24">
      <div class="mx-auto max-w-3xl text-center">
        <p class="mb-4 inline-flex items-center rounded-full border border-black/10 bg-[var(--bg-elevated)] px-4 py-1.5 text-xs font-semibold tracking-wide text-eucalyptus-700 dark:border-white/15 dark:text-eucalyptus-300">
          Fin-Tools Hub — Startup Finance
        </p>
        <h1 class="text-balance text-3xl font-bold text-text-primary-light dark:text-text-primary-dark sm:text-4xl">
          Startup Runway & Burn Rate
        </h1>
        <p class="mt-3 text-pretty text-base text-text-secondary-light dark:text-text-secondary-dark sm:text-lg">
          CFO-grade Finanzmodellierung: Headcount-Plan, MRR-Wachstum, Kapitalinjektionen und Death-Valley-Erkennung — direkt im Browser, keine Serverübertragung.
        </p>
      </div>
    </section>

    <section class="mx-auto mt-10 w-full max-w-6xl px-4 md:px-6">
      <RunwayApp client:visible />
    </section>
  </main>
</BaseLayout>
