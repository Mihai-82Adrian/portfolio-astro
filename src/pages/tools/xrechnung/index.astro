---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { Wrench } from '@lucide/astro';
import { generateBreadcrumbSchema } from '@utils/structuredData';

const title = 'XRechnung Generator | Mihai Adrian Mateescu';
const description =
  'Coming soon: browser-first XRechnung XML generator for Germany (EN 16931).';

const breadcrumbSchema = generateBreadcrumbSchema([
  { name: 'Home', url: 'https://me-mateescu.de/' },
  { name: 'Tools', url: 'https://me-mateescu.de/tools' },
  { name: 'XRechnung Generator', url: 'https://me-mateescu.de/tools/xrechnung' },
]);
---

<BaseLayout title={title} description={description} lang="en" structuredData={breadcrumbSchema}>
  <main class="pb-20">
    <section class="mx-auto w-full max-w-3xl px-4 pt-24 text-center md:px-6">
      <div class="rounded-2xl border border-black/10 bg-[var(--bg-elevated)] p-8 dark:border-white/10">
        <span class="mx-auto inline-flex h-12 w-12 items-center justify-center rounded-xl border border-black/10 bg-eucalyptus-100 text-eucalyptus-700 dark:border-white/10 dark:bg-eucalyptus-900/35 dark:text-eucalyptus-300">
          <Wrench class="h-6 w-6" aria-hidden="true" />
        </span>
        <h1 class="mt-5 text-balance text-3xl font-bold text-text-primary-light dark:text-text-primary-dark">
          XRechnung Tool under active development
        </h1>
        <p class="mt-3 text-pretty text-text-secondary-light dark:text-text-secondary-dark">
          Coming Soon: Tool under active development.
        </p>
        <p class="mt-4 text-sm text-text-muted-light dark:text-text-muted-dark">
          Local-only, no server storage.
        </p>
      </div>
    </section>
  </main>
</BaseLayout>
