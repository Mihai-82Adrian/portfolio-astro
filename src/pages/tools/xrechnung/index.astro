---
import BaseLayout from '@/layouts/BaseLayout.astro';
import XRechnungApp from '@/components/tools/xrechnung/XRechnungApp.svelte';
import { generateBreadcrumbSchema } from '@utils/structuredData';

const title = 'XRechnung XML Generator 2026';
const description =
  'XRechnung-XML nach EN 16931 und KoSIT v3.0 direkt im Browser erstellen: UBL 2.1 oder CII-Syntax, DIN-5008-PDF-Export, Kleinunternehmer & Reverse Charge.';

const breadcrumbSchema = generateBreadcrumbSchema([
  { name: 'Home', url: 'https://me-mateescu.de/' },
  { name: 'Tools', url: 'https://me-mateescu.de/tools' },
  { name: 'XRechnung Generator', url: 'https://me-mateescu.de/tools/xrechnung' },
]);
---

<BaseLayout title={title} description={description} lang="de" ogImage="/images/tools/og-xrechnung.webp" structuredData={breadcrumbSchema}>
  <main class="pb-20">
    <section class="mx-auto w-full max-w-6xl px-4 pt-20 md:px-6 md:pt-24">
      <div class="mx-auto max-w-3xl text-center">
        <h1 class="text-balance text-3xl font-bold text-text-primary-light dark:text-text-primary-dark sm:text-4xl">
          XRechnung (EN 16931) XML Generator
        </h1>
        <p class="mt-3 text-pretty text-base text-text-secondary-light dark:text-text-secondary-dark sm:text-lg">
          Lokales Tool: Erstelle konforme XML-Dateien mit Live-Vorschau und direktem Export im Browser.
        </p>
        <p class="mt-2 text-sm text-text-muted-light dark:text-text-muted-dark font-medium">
          Validiert gegen KoSIT Validator v1.6.2 (Config v3.0.2) + EN16931. Zero-Tracking (keine Server-Speicherung).
        </p>
      </div>
    </section>

    <section class="mx-auto mt-10 w-full max-w-6xl px-4 md:px-6">
      <XRechnungApp client:visible />
    </section>
  </main>
</BaseLayout>
