---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import PostList from '@/components/blog/PostList.astro';
import Container from '@components/ui/Container.astro';

export async function getStaticPaths() {
  const allPosts = await getCollection('blog', ({ data }) => !data.draft);

  const categories = [...new Set(allPosts.map(post => post.data.category))];

  return categories.map(category => ({
    params: { category },
    props: {
      category,
      posts: allPosts
        .filter(post => post.data.category === category)
        .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
    },
  }));
}

interface Props {
  category: string;
  posts: CollectionEntry<'blog'>[];
}

const { category, posts } = Astro.props;

const categoryDisplayOverrides: Record<string, string> = {
  'ai-ml': 'AI & ML',
};

const categoryDisplay = categoryDisplayOverrides[category] ?? category
  .split('-')
  .map(word => word.charAt(0).toUpperCase() + word.slice(1))
  .join(' ');

const categoryDescriptions: Record<string, string> = {
  'finance': 'Articles about financial theory, accounting, and economics.',
  'ai-ml': 'Deep dives into artificial intelligence, machine learning, and data science.',
  'fintech': 'Exploring the intersection of finance and technology.',
  'personal': 'Personal reflections, career insights, and professional development.',
};

const title = `${categoryDisplay} — Blog`;
const description = categoryDescriptions[category] || `Articles about ${categoryDisplay}.`;
---

<BaseLayout
  title={title}
  description={description}
  ogType="website"
  lang="en"
>
  <section class="py-16 md:py-24">
    <Container maxWidth="lg">
      <!-- Breadcrumb -->
      <nav aria-label="Breadcrumb" class="text-sm text-text-secondary-light dark:text-text-secondary-dark mb-8">
        <ol class="flex items-center gap-2 list-none p-0 m-0">
          <li>
            <a href="/" class="hover:text-eucalyptus-700 dark:hover:text-eucalyptus-300 transition-colors">
              Home
            </a>
          </li>
          <li aria-hidden="true" class="text-text-tertiary-light dark:text-text-tertiary-dark">/</li>
          <li>
            <a href="/blog" class="hover:text-eucalyptus-700 dark:hover:text-eucalyptus-300 transition-colors">
              Blog
            </a>
          </li>
          <li aria-hidden="true" class="text-text-tertiary-light dark:text-text-tertiary-dark">/</li>
          <li aria-current="page" class="text-text-tertiary-light dark:text-text-tertiary-dark">
            {categoryDisplay}
          </li>
        </ol>
      </nav>

      <!-- Page Header -->
      <div class="mb-12">
        <div class="inline-block px-4 py-2 bg-eucalyptus-100 dark:bg-eucalyptus-900 text-eucalyptus-800 dark:text-eucalyptus-200 rounded-md mb-4 text-sm font-medium">
          Category
        </div>
        <h1 class="text-4xl md:text-5xl font-bold text-text-primary-light dark:text-text-primary-dark mb-4">
          {categoryDisplay}
        </h1>
        <p class="text-xl text-text-secondary-light dark:text-text-secondary-dark max-w-3xl">
          {description}{' '}
          <span class="text-eucalyptus-700 dark:text-eucalyptus-300 font-semibold">
            {posts.length} {posts.length === 1 ? 'article' : 'articles'}
          </span>
        </p>
      </div>

      <!-- Category Filter -->
      <nav aria-label="Category filter" class="mb-8 flex flex-wrap gap-2">
        <a
          href="/blog"
          class="px-4 py-2 bg-light-surface dark:bg-dark-surface text-text-secondary-light dark:text-text-secondary-dark rounded-md hover:bg-eucalyptus-100 dark:hover:bg-eucalyptus-900 hover:text-eucalyptus-800 dark:hover:text-eucalyptus-200 transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-eucalyptus-500 focus-visible:ring-offset-2"
        >
          All Posts
        </a>
        {['finance', 'ai-ml', 'fintech', 'personal'].map(cat => (
          <a
            href={`/blog/category/${cat}`}
            aria-current={cat === category ? 'page' : undefined}
            class:list={[
              'px-4 py-2 rounded-md transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-eucalyptus-500 focus-visible:ring-offset-2',
              cat === category
                ? 'bg-eucalyptus-700 text-white font-semibold'
                : 'bg-light-surface dark:bg-dark-surface text-text-secondary-light dark:text-text-secondary-dark hover:bg-eucalyptus-100 dark:hover:bg-eucalyptus-900 hover:text-eucalyptus-800 dark:hover:text-eucalyptus-200'
            ]}
          >
            {cat.split('-').map(word => word.charAt(0).toUpperCase() + word.slice(1)).join(' ')}
          </a>
        ))}
      </nav>

      <!-- Posts -->
      <h2 class="sr-only">Articles</h2>
      {posts.length > 0 ? (
        <PostList posts={posts} />
      ) : (
        <div class="text-center py-16">
          <p class="text-xl text-text-secondary-light dark:text-text-secondary-dark">
            No articles in this category yet. Check back soon!
          </p>
          <a
            href="/blog"
            class="inline-block mt-6 px-6 py-3 bg-eucalyptus-700 text-white rounded-md font-semibold hover:bg-eucalyptus-800 transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-eucalyptus-500 focus-visible:ring-offset-2"
          >
            View All Posts
          </a>
        </div>
      )}

      <!-- Back to Blog -->
      <div class="mt-12 text-center">
        <a
          href="/blog"
          class="inline-flex items-center gap-2 text-eucalyptus-800 dark:text-eucalyptus-200 underline decoration-eucalyptus-600/50 dark:decoration-eucalyptus-400/50 hover:decoration-eucalyptus-700 dark:hover:decoration-eucalyptus-300 rounded focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-eucalyptus-500 focus-visible:ring-offset-2"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
          </svg>
          Back to all posts
        </a>
      </div>
    </Container>
  </section>
</BaseLayout>
