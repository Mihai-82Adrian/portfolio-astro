---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import PostList from '@/components/blog/PostList.astro';
import Container from '@components/ui/Container.astro';

export async function getStaticPaths() {
  const allPosts = await getCollection('blog', ({ data }) => !data.draft);

  const allTags = new Set<string>();
  allPosts.forEach(post => {
    post.data.tags.forEach((tag: string) => allTags.add(tag));
  });

  return Array.from(allTags).map((tag: string) => ({
    params: { tag },
    props: {
      tag,
      posts: allPosts
        .filter(post => post.data.tags.includes(tag))
        .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
    },
  }));
}

interface Props {
  tag: string;
  posts: CollectionEntry<'blog'>[];
}

const { tag, posts } = Astro.props;

const tagDisplay = tag
  .split('-')
  .map((word: string) => word.charAt(0).toUpperCase() + word.slice(1))
  .join(' ');

// Per-tag SEO descriptions — keyword-rich, 90–160 chars
const tagDescriptions: Record<string, string> = {
  'accounting':          'Articles on accounting methodology, bookkeeping practices, and German accounting standards (HGB, GoBD).',
  'anomaly-detection':   'Technical guides on anomaly detection algorithms and their application in financial data analysis.',
  'astro':               'Building with Astro — static site generation, island architecture, and performance-first web development.',
  'automation':          'Articles on automating financial workflows, document processing, and accounting operations.',
  'benchmarking':        'Guides on performance benchmarking — measurement methodology, profiling tools, and reproducible benchmarks.',
  'best-practices':      'Articles on software engineering best practices — code quality, testing, and production-ready patterns.',
  'compliance':          'Deep dives into financial compliance, regulatory frameworks, and audit-ready practices for DACH businesses.',
  'dach':                'Finance and technology content for the German-speaking DACH market — Germany, Austria, and Switzerland.',
  'document-ai':         'AI-powered document understanding — OCR, invoice intelligence, and unstructured data extraction at scale.',
  'en16931':             'Technical articles on the European e-invoicing standard EN 16931 and XRechnung implementation for DACH.',
  'explainability':      'Articles on AI explainability — interpretable models, SHAP values, and audit-ready machine learning.',
  'fintech':             'Exploring financial technology — digital payments, banking APIs, and tech-driven financial services.',
  'frontend-architecture': 'Articles on frontend architecture — component design, performance patterns, and maintainable web applications.',
  'gobd':                'Technical guides on GoBD compliance — German regulations for digital bookkeeping and audit trails.',
  'ifrs':                'Articles on IFRS — International Financial Reporting Standards and their application in accounting practice.',
  'julia':               'Performance and productivity with the Julia programming language — type stability, speed, and scientific computing.',
  'lifetimes':           'Understanding Rust lifetimes — borrow checker rules, lifetime annotations, and safe ownership patterns.',
  'llm':                 'Practical guides on large language models — structured outputs, prompt engineering, and LLM-powered applications.',
  'local-first':         'Essays on local-first software — privacy-preserving, offline-capable applications without vendor lock-in.',
  'machine-learning':    'Applied machine learning — model selection, training, evaluation, and production-grade ML engineering.',
  'memory-safety':       'Memory-safe programming — Rust ownership, borrow checking, and writing reliable systems software.',
  'openai':              'Building with the OpenAI API — GPT models, structured outputs, and production-grade AI integrations.',
  'ownership':           'Rust ownership and borrowing — the rules that make Rust memory-safe without a garbage collector.',
  'performance':         'Software performance engineering — profiling, optimization, and eliminating bottlenecks in real-world code.',
  'prompt-engineering':  'Effective LLM prompting — few-shot examples, chain-of-thought, and structured output strategies.',
  'rust':                'Systems programming with Rust — ownership, lifetimes, memory safety, and high-performance patterns.',
  'scientific-computing': 'Scientific computing with Julia — numerical methods, performance optimization, and reproducible research.',
  'structured-outputs':  'Using OpenAI Structured Outputs and JSON schema to extract typed data from unstructured text reliably.',
  'svelte':              'Building reactive UIs with Svelte 5 — Runes, reactive state, and performant island architecture.',
  'tailwind':            'Styling with Tailwind CSS — utility-first design, custom tokens, and maintainable CSS at scale.',
  'typescript':          'Type-safe development with TypeScript — advanced types, generics, and building reliable JavaScript applications.',
  'web-development':     'Modern web development — frameworks, tooling, and engineering practices for production-grade applications.',
  'xrechnung':           'Building and validating XRechnung XML invoices — EN 16931, KoSIT v3.0, and UBL/CII syntax for DACH.',
  'zod':                 'Runtime type validation with Zod — schema definition, parsing, and integration with TypeScript and OpenAI.',
  'zugferd':             'ZUGFeRD e-invoice format — embedded PDF/A invoices with machine-readable XML for DACH businesses.',
};

const description = tagDescriptions[tag]
  ?? `Articles tagged with #${tagDisplay}. ${posts.length} ${posts.length === 1 ? 'article' : 'articles'} on ${tagDisplay} in finance, AI, and software engineering.`;

const title = `#${tagDisplay} — Blog | Mihai Adrian Mateescu`;

// Related tags (tags that co-occur with the current tag)
const relatedTagsMap = new Map<string, number>();
posts.forEach(post => {
  post.data.tags.forEach((t: string) => {
    if (t !== tag) {
      relatedTagsMap.set(t, (relatedTagsMap.get(t) || 0) + 1);
    }
  });
});
const relatedTags = Array.from(relatedTagsMap.entries())
  .sort((a, b) => b[1] - a[1])
  .slice(0, 10)
  .map(([tagName]) => tagName);
---

<BaseLayout
  title={title}
  description={description}
  ogType="website"
  lang="en"
>
  <section class="py-16 md:py-24">
    <Container maxWidth="lg">
      <!-- Breadcrumb -->
      <nav aria-label="Breadcrumb" class="text-sm text-text-secondary-light dark:text-text-secondary-dark mb-8">
        <ol class="flex items-center gap-2 list-none p-0 m-0">
          <li>
            <a href="/" class="hover:text-eucalyptus-700 dark:hover:text-eucalyptus-300 transition-colors">
              Home
            </a>
          </li>
          <li aria-hidden="true" class="text-text-tertiary-light dark:text-text-tertiary-dark">/</li>
          <li>
            <a href="/blog" class="hover:text-eucalyptus-700 dark:hover:text-eucalyptus-300 transition-colors">
              Blog
            </a>
          </li>
          <li aria-hidden="true" class="text-text-tertiary-light dark:text-text-tertiary-dark">/</li>
          <li aria-current="page" class="text-text-tertiary-light dark:text-text-tertiary-dark">
            #{tagDisplay}
          </li>
        </ol>
      </nav>

      <!-- Page Header -->
      <div class="mb-12">
        <div class="inline-block px-4 py-2 bg-eucalyptus-100 dark:bg-eucalyptus-900 text-eucalyptus-800 dark:text-eucalyptus-200 rounded-md mb-4 text-sm font-medium">
          Tag
        </div>
        <h1 class="text-4xl md:text-5xl font-bold text-text-primary-light dark:text-text-primary-dark mb-4">
          #{tagDisplay}
        </h1>
        <p class="text-xl text-text-secondary-light dark:text-text-secondary-dark max-w-3xl">
          {description}{' '}
          <span class="text-eucalyptus-700 dark:text-eucalyptus-300 font-semibold">
            {posts.length} {posts.length === 1 ? 'article' : 'articles'}
          </span>
        </p>
      </div>

      <!-- Posts -->
      <h2 class="sr-only">Articles</h2>
      {posts.length > 0 ? (
        <PostList posts={posts} />
      ) : (
        <div class="text-center py-16">
          <p class="text-xl text-text-secondary-light dark:text-text-secondary-dark">
            No articles with this tag yet. Check back soon!
          </p>
          <a
            href="/blog"
            class="inline-block mt-6 px-6 py-3 bg-eucalyptus-700 text-white rounded-md font-semibold hover:bg-eucalyptus-800 transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-eucalyptus-500 focus-visible:ring-offset-2"
          >
            View All Posts
          </a>
        </div>
      )}

      <!-- Related Tags -->
      {relatedTags.length > 0 && (
        <div class="mt-16 p-6 bg-light-surface dark:bg-dark-surface rounded-lg border border-eucalyptus-200 dark:border-eucalyptus-800">
          <h2 class="text-xl font-bold mb-4 text-text-primary-light dark:text-text-primary-dark">
            Related Tags
          </h2>
          <div class="flex flex-wrap gap-2">
            {relatedTags.map((relatedTag: string) => (
              <a
                href={`/blog/tag/${relatedTag}`}
                class="px-3 py-1 bg-light-bg dark:bg-dark-bg text-text-secondary-light dark:text-text-secondary-dark rounded-md hover:bg-eucalyptus-100 dark:hover:bg-eucalyptus-900 hover:text-eucalyptus-800 dark:hover:text-eucalyptus-200 transition-colors border border-eucalyptus-200 dark:border-eucalyptus-800 text-sm focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-eucalyptus-500 focus-visible:ring-offset-2"
              >
                #{relatedTag.split('-').map((w: string) => w.charAt(0).toUpperCase() + w.slice(1)).join(' ')}
              </a>
            ))}
          </div>
        </div>
      )}

      <!-- Back to Blog -->
      <div class="mt-12 text-center">
        <a
          href="/blog"
          class="inline-flex items-center gap-2 text-eucalyptus-800 dark:text-eucalyptus-200 underline decoration-eucalyptus-600/50 dark:decoration-eucalyptus-400/50 hover:decoration-eucalyptus-700 dark:hover:decoration-eucalyptus-300 rounded focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-eucalyptus-500 focus-visible:ring-offset-2"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
          </svg>
          Back to all posts
        </a>
      </div>
    </Container>
  </section>
</BaseLayout>
