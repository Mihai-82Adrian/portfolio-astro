---
interface Props {
  tech: {
    name: string;
    icon: string;
    category?: 'language' | 'framework' | 'platform' | 'domain' | 'data' | 'paradigm' | 'service' | 'region';
  };
  size?: 'sm' | 'md' | 'lg';
}

const { tech, size = 'md' } = Astro.props;

import tokens from '../../data/design-tokens.json';

const categoryConfig = {
  language: {
    color: tokens.colors.info.DEFAULT,
    bgColor: tokens.colors.info.light,
    borderColor: tokens.colors.info.dark,
  },
  framework: {
    color: tokens.colors.taupe[500],
    bgColor: tokens.colors.taupe[100],
    borderColor: tokens.colors.taupe[300],
  },
  platform: {
    color: tokens.colors.success.DEFAULT,
    bgColor: tokens.colors.success.light,
    borderColor: tokens.colors.success.dark,
  },
  domain: {
    color: tokens.colors.warning.DEFAULT,
    bgColor: tokens.colors.warning.light,
    borderColor: tokens.colors.warning.dark,
  },
  data: {
    color: tokens.colors.info.dark,
    bgColor: tokens.colors.info.light,
    borderColor: tokens.colors.info.DEFAULT,
  },
  paradigm: {
    color: tokens.colors.eucalyptus[400],
    bgColor: tokens.colors.eucalyptus[100],
    borderColor: tokens.colors.eucalyptus[300],
  },
  service: {
    color: tokens.colors.taupe[600],
    bgColor: tokens.colors.taupe[100],
    borderColor: tokens.colors.taupe[400],
  },
  region: {
    color: tokens.colors.error.DEFAULT,
    bgColor: tokens.colors.error.light,
    borderColor: tokens.colors.error.dark,
  },
};

const config = categoryConfig[tech.category || 'platform'];
---

<span 
  class={`tech-badge badge-${size}`}
  data-category={tech.category}
  title={`${tech.name}${tech.category ? ` (${tech.category})` : ''}`}
>
  <span class="tech-icon" aria-hidden="true">{tech.icon}</span>
  <span class="tech-name">{tech.name}</span>
</span>

<style define:vars={{ 
  badgeColor: config.color,
  badgeBg: config.bgColor,
  badgeBorder: config.borderColor
}}>
  .tech-badge {
    display: inline-flex;
    align-items: center;
    border-radius: 9999px;
    background: var(--badgeBg);
    border: 1px solid var(--badgeBorder);
    font-family: var(--font-body);
    font-weight: 500;
    color: var(--badgeColor);
    white-space: nowrap;
    transition: all 0.2s ease;
    cursor: default;
  }

  /* Size variants */
  .badge-sm {
    padding: 0.125rem 0.5rem;
    font-size: 0.75rem;
    gap: 0.25rem;
  }

  .badge-md {
    padding: 0.25rem 0.75rem;
    font-size: 0.875rem;
    gap: 0.375rem;
  }

  .badge-lg {
    padding: 0.375rem 1rem;
    font-size: 1rem;
    gap: 0.5rem;
  }

  .tech-badge:hover {
    background: var(--badgeColor);
    color: white;
    border-color: var(--badgeColor);
    box-shadow: 0 0 12px var(--badgeBorder);
    transform: translateY(-1px) scale(1.05);
  }

  .tech-icon {
    font-size: 1em;
    line-height: 1;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .tech-name {
    line-height: 1.2;
  }

  /* Accessibility - focus state */
  .tech-badge:focus-visible {
    outline: 2px solid var(--badgeColor);
    outline-offset: 2px;
  }

  /* Dark mode adjustments (class-based, aligned with site theme toggle) */
  :global(.dark) .tech-badge {
    background: rgba(0, 0, 0, 0.3);
    border-color: var(--badgeColor);
  }

  :global(.dark) .tech-badge:hover {
    background: var(--badgeColor);
    color: white;
  }

  /* Print styles */
  @media print {
    .tech-badge {
      border: 1px solid var(--badgeColor);
      background: white;
      color: var(--badgeColor);
    }
  }

  /* Responsive font sizing */
  @media (max-width: 768px) {
    .tech-badge {
      font-size: 0.875em;
    }
  }

  /* Animation for initial load */
  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(4px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .tech-badge {
    animation: fadeIn 0.3s ease-out;
  }
</style>
