
---
/**
 * ChatWidget Component — V2
 *
 * Tabbed AI Chat interface with:
 * - 💬 Chat tab (intent router + quick action chips)
 * - 📄 JD Analysis tab (structured fit analysis)
 * - 🌐 Language selector (Auto | DE | EN | RO)
 *
 * @component
 */
interface Props {
  class?: string;
  id?: string;
  title?: string;
  subtitle?: string;
}

const props = Astro.props;
const className = props.class || '';
const id = props.id || 'ai-chat-widget';
const title = props.title || 'Ask Mihai \u00b7 AI';
const subtitle = props.subtitle || 'Powered by GPT-4.1';
---

<div id={id} class:list={["chat-widget flex flex-col bg-white dark:bg-dark-surface border-gray-200 dark:border-dark-border overflow-hidden w-full h-full", className]} data-chat-widget>
  <!-- Header -->
  <div class="bg-eucalyptus-600 p-4 text-white flex justify-between items-center shrink-0">
    <div class="flex items-center gap-2">
      <span class="text-lg" aria-hidden="true">🤖</span>
      <div>
        <h3 class="font-bold text-lg leading-tight">{title}</h3>
        <p class="text-xs text-eucalyptus-100">{subtitle}</p>
      </div>
    </div>
    <div class="flex items-center gap-2">
      <!-- Language Selector -->
      <select
        class="chat-lang-select bg-eucalyptus-700 text-white text-xs rounded-lg px-2 py-1 border border-eucalyptus-500 focus:ring-2 focus:ring-white cursor-pointer"
        aria-label="Response language"
      >
        <option value="auto">🌐 Auto</option>
        <option value="de">🇩🇪 DE</option>
        <option value="en">🇬🇧 EN</option>
        <option value="ro">🇷🇴 RO</option>
      </select>
      <slot name="header-actions" />
    </div>
  </div>

  <!-- Tab Bar -->
  <div class="chat-tab-bar flex border-b border-gray-200 dark:border-dark-border bg-white dark:bg-dark-surface shrink-0" role="tablist">
    <button
      class="chat-tab flex-1 px-4 py-2.5 text-sm font-medium transition-colors focus-visible:ring-2 focus-visible:ring-eucalyptus-500"
      role="tab"
      aria-selected="true"
      aria-controls="chat-panel-chat"
      data-tab="chat"
    >
      💬 Chat
    </button>
    <button
      class="chat-tab flex-1 px-4 py-2.5 text-sm font-medium transition-colors focus-visible:ring-2 focus-visible:ring-eucalyptus-500"
      role="tab"
      aria-selected="false"
      aria-controls="chat-panel-jd"
      data-tab="jd"
    >
      📄 JD Analysis
    </button>
  </div>

  <!-- ═══ Chat Tab Panel ═══ -->
  <div id="chat-panel-chat" class="chat-panel flex flex-col flex-1 overflow-hidden" role="tabpanel" data-panel="chat">
    <!-- Messages Area -->
    <div class="chat-messages flex-1 overflow-y-auto p-4 space-y-3 bg-gray-50 dark:bg-dark-bg" aria-live="polite" aria-atomic="false">
      <!-- Welcome Message -->
      <div class="message ai bg-white dark:bg-dark-elevated p-3 rounded-lg rounded-tl-none shadow-subtle text-sm dark:text-gray-200 border border-gray-100 dark:border-dark-border max-w-88">
        <p>Hi! I'm Mihai's AI assistant. I can answer questions about his skills, experience, certifications, and projects.</p>
        <span class="text-xs text-text-secondary-light dark:text-text-secondary-dark mt-2 block">⚠️ Answers may be generated and could contain errors.</span>
      </div>

      <!-- Quick Action Chips -->
      <div class="quick-chips flex flex-wrap gap-2 mt-1">
        <button class="chip-btn" data-chip="contact" type="button">📋 Contact</button>
        <button class="chip-btn" data-chip="current_role" type="button">💼 Current Role</button>
        <button class="chip-btn" data-chip="certifications" type="button">🎓 Certifications</button>
        <button class="chip-btn" data-chip="projects" type="button">🚀 Projects</button>
      </div>
    </div>

    <!-- Chat Input -->
    <form class="chat-form p-3 bg-white dark:bg-dark-surface border-t border-gray-200 dark:border-dark-border flex gap-2 items-end shrink-0">
      <textarea
        placeholder="Ask a question..."
        aria-label="Chat Message"
        rows="1"
        maxlength="4000"
        class="chat-input flex-1 px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-2xl focus:ring-2 focus:ring-eucalyptus-500 dark:bg-dark-elevated dark:text-white text-sm resize-none overflow-hidden max-h-32"
        required
      ></textarea>
      <button
        type="submit"
        aria-label="Send Message"
        class="chat-send-btn bg-eucalyptus-600 hover:bg-eucalyptus-700 text-white p-2 rounded-full transition-colors disabled:opacity-50 disabled:cursor-not-allowed shrink-0"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 rotate-90" viewBox="0 0 20 20" fill="currentColor">
          <path d="M10.894 2.553a1 1 0 00-1.788 0l-7 14a1 1 0 001.169 1.409l5-1.429A1 1 0 009 15.571V11a1 1 0 112 0v4.571a1 1 0 00.725.962l5 1.428a1 1 0 001.17-1.408l-7-14z" />
        </svg>
      </button>
    </form>
    <!-- Quota Badge -->
    <div class="quota-badge px-3 py-1.5 text-xs text-text-tertiary-light dark:text-text-tertiary-dark flex items-center gap-3 border-t border-gray-100 dark:border-dark-border bg-white dark:bg-dark-surface shrink-0">
      <span class="quota-chat-text">💬 4/4 questions</span>
      <span class="text-gray-300 dark:text-gray-600">|</span>
      <span class="quota-jd-text">📄 1/1 JD analysis</span>
    </div>
  </div>

  <!-- ═══ JD Analysis Tab Panel ═══ -->
  <div id="chat-panel-jd" class="chat-panel flex flex-col flex-1 overflow-hidden hidden" role="tabpanel" data-panel="jd">
    <!-- JD Content -->
    <div class="flex-1 overflow-y-auto p-4 bg-gray-50 dark:bg-dark-bg">
      <!-- JD Hero -->
      <div class="text-center mb-4">
        <div class="inline-flex items-center gap-2 bg-eucalyptus-50 dark:bg-eucalyptus-950 text-eucalyptus-700 dark:text-eucalyptus-300 px-3 py-1.5 rounded-full text-xs font-medium mb-2">
          <span aria-hidden="true">📊</span> Professional Fit Analysis
        </div>
        <p class="text-sm text-gray-600 dark:text-gray-400">Paste a job description to receive a detailed match analysis with scores and recommendations.</p>
      </div>

      <!-- Structure Guide (collapsible) -->
      <details class="jd-guide mb-3 bg-white dark:bg-dark-elevated rounded-lg border border-gray-200 dark:border-dark-border">
        <summary class="px-3 py-2 text-xs font-medium text-gray-600 dark:text-gray-400 cursor-pointer hover:text-eucalyptus-600 transition-colors select-none">
          📋 Tips for best results
        </summary>
        <div class="px-3 pb-3 text-xs text-gray-500 dark:text-gray-400 space-y-1">
          <p>For the most accurate analysis, include:</p>
          <ul class="list-disc pl-4 space-y-0.5">
            <li>Job Title & Company name</li>
            <li>Required Qualifications & Experience</li>
            <li>Key Responsibilities</li>
            <li>Nice-to-haves & Bonus skills</li>
            <li>Location & Work model (remote/hybrid/onsite)</li>
          </ul>
        </div>
      </details>

      <!-- JD Textarea -->
      <textarea
        class="jd-input w-full p-3 border border-gray-300 dark:border-gray-600 rounded-xl focus:ring-2 focus:ring-eucalyptus-500 dark:bg-dark-elevated dark:text-white text-sm resize-none"
        placeholder="Paste the full job description here..."
        rows="10"
        maxlength="6000"
        aria-label="Job Description Input"
      ></textarea>

      <!-- Character Counter -->
      <div class="flex justify-between items-center mt-2">
        <span class="jd-char-count text-xs text-gray-400">0 / 6,000</span>
        <button
          type="button"
          class="jd-analyze-btn bg-eucalyptus-600 hover:bg-eucalyptus-700 text-white px-4 py-2 rounded-xl text-sm font-medium transition-all disabled:opacity-50 disabled:cursor-not-allowed flex items-center gap-2 shadow-subtle hover:shadow-elevated"
          disabled
        >
          <span aria-hidden="true">🔍</span> Analyze Fit
        </button>
      </div>

      <!-- JD Results Container -->
      <div class="jd-results mt-4 hidden"></div>
    </div>
  </div>
</div>

<script>
  class ChatWidget {
    container: HTMLElement;
    // Chat tab elements
    form: HTMLFormElement;
    input: HTMLTextAreaElement;
    messagesEl: HTMLElement;
    submitBtn: HTMLButtonElement | null;
    chipsContainer: HTMLElement | null;
    // JD tab elements
    jdInput: HTMLTextAreaElement | null;
    jdAnalyzeBtn: HTMLButtonElement | null;
    jdCharCount: HTMLElement | null;
    jdResults: HTMLElement | null;
    // Tab & language
    tabs: NodeListOf<HTMLButtonElement>;
    panels: NodeListOf<HTMLElement>;
    langSelect: HTMLSelectElement | null;
    // Quota elements
    quotaBadge: HTMLElement | null;
    quotaChatText: HTMLElement | null;
    quotaJdText: HTMLElement | null;
    activeTab: string = 'chat';

    constructor(el: HTMLElement) {
      this.container = el;
      this.form = el.querySelector('.chat-form') as HTMLFormElement;
      this.input = el.querySelector('.chat-input') as HTMLTextAreaElement;
      this.messagesEl = el.querySelector('.chat-messages') as HTMLElement;
      this.submitBtn = this.form.querySelector('.chat-send-btn');
      this.chipsContainer = el.querySelector('.quick-chips');

      this.jdInput = el.querySelector('.jd-input');
      this.jdAnalyzeBtn = el.querySelector('.jd-analyze-btn');
      this.jdCharCount = el.querySelector('.jd-char-count');
      this.jdResults = el.querySelector('.jd-results');

      this.tabs = el.querySelectorAll('.chat-tab');
      this.panels = el.querySelectorAll('.chat-panel');
      this.langSelect = el.querySelector('.chat-lang-select');

      this.quotaBadge = el.querySelector('.quota-badge');
      this.quotaChatText = el.querySelector('.quota-chat-text');
      this.quotaJdText = el.querySelector('.quota-jd-text');

      this.init();
    }

    init() {
      // Tab switching
      this.tabs.forEach(tab => {
        tab.addEventListener('click', () => this.switchTab(tab.dataset.tab || 'chat'));
      });

      // Chat form
      this.form.addEventListener('submit', (e) => this.handleChatSubmit(e));

      // Auto-resize textarea
      this.input.addEventListener('input', () => {
        this.input.style.height = 'auto';
        this.input.style.height = Math.min(this.input.scrollHeight, 128) + 'px';
      });

      // Enter to send, Shift+Enter for newline
      this.input.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' && !e.shiftKey) {
          e.preventDefault();
          this.form.requestSubmit();
        }
      });

      // Quick action chips
      this.chipsContainer?.querySelectorAll('.chip-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          const chip = (btn as HTMLElement).dataset.chip || '';
          this.handleChipClick(chip);
        });
      });

      // JD Analysis
      if (this.jdInput) {
        this.jdInput.addEventListener('input', () => this.updateJdCharCount());
      }
      if (this.jdAnalyzeBtn) {
        this.jdAnalyzeBtn.addEventListener('click', () => this.handleJdAnalyze());
      }
    }

    // ─── Helpers ─────────────────────────────────────────────────

    clearElement(el: HTMLElement) {
      while (el.firstChild) {
        el.removeChild(el.firstChild);
      }
    }

    getCookieConsentHeader(): string {
      try {
        const consent = localStorage.getItem('cookie-consent');
        return consent === 'true' || consent === 'granted' ? 'granted' : 'denied';
      } catch {
        return 'denied';
      }
    }

    getApiHeaders(): Record<string, string> {
      return {
        'Content-Type': 'application/json',
        'X-Cookie-Consent': this.getCookieConsentHeader(),
      };
    }

    updateQuota(quotaData: { q: number; jd: number; maxQ: number; maxJd: number } | undefined) {
      if (!quotaData || !this.quotaChatText || !this.quotaJdText) return;

      const chatRemaining = quotaData.maxQ - quotaData.q;
      const jdRemaining = quotaData.maxJd - quotaData.jd;

      this.quotaChatText.textContent = `\u{1F4AC} ${chatRemaining}/${quotaData.maxQ} questions`;
      this.quotaJdText.textContent = `\u{1F4C4} ${jdRemaining}/${quotaData.maxJd} JD analysis`;

      // Color coding
      const chatColor = chatRemaining === 0 ? 'text-error' : chatRemaining === 1 ? 'text-warning' : 'text-gray-400 dark:text-gray-500';
      const jdColor = jdRemaining === 0 ? 'text-error' : 'text-gray-400 dark:text-gray-500';

      this.quotaChatText.className = `quota-chat-text ${chatColor}`;
      this.quotaJdText.className = `quota-jd-text ${jdColor}`;

      // Disable inputs if exhausted
      if (chatRemaining === 0 && this.activeTab === 'chat') {
        this.input.disabled = true;
        this.input.placeholder = 'Session limit reached. Come back tomorrow!';
        if (this.submitBtn) this.submitBtn.disabled = true;
      }
      if (jdRemaining === 0 && this.jdAnalyzeBtn) {
        this.jdAnalyzeBtn.disabled = true;
      }
    }

    // ─── Tab Management ─────────────────────────────────────────

    switchTab(tabId: string) {
      this.activeTab = tabId;
      this.tabs.forEach(tab => {
        const isActive = tab.dataset.tab === tabId;
        tab.setAttribute('aria-selected', isActive ? 'true' : 'false');
        tab.classList.toggle('tab-active', isActive);
        tab.classList.toggle('tab-inactive', !isActive);
      });
      this.panels.forEach(panel => {
        const isActive = panel.dataset.panel === tabId;
        panel.classList.toggle('hidden', !isActive);
      });
    }

    // ─── Quick Action Chips ─────────────────────────────────────

    async handleChipClick(chipType: string) {
      const chipLabels: Record<string, string> = {
        contact: '📋 Show contact info',
        current_role: '💼 What is the current role?',
        certifications: '🎓 List certifications',
        projects: '🚀 What are the current projects?',
      };

      const displayText = chipLabels[chipType] || chipType;
      this.appendMessage(displayText, true);

      this.showLoading();

      try {
        const lang = this.langSelect?.value || 'auto';
        const res = await fetch('/api/chat', {
          method: 'POST',
          headers: this.getApiHeaders(),
          body: JSON.stringify({ message: displayText, lang, tab: 'chat', intent: chipType })
        });

        this.removeLoading();

        if (!res.ok) {
          throw new Error(await this.parseError(res));
        }

        const contentType = res.headers.get('Content-Type') || '';
        if (contentType.includes('text/event-stream')) {
          await this.consumeStream(res);
        } else {
          // Non-streaming (fact responses)
          const data = await res.json();
          this.appendMessage(data.answer, false, data.sources);
          this.updateQuota(data.quota);
        }

      } catch (err: any) {
        this.removeLoading();
        this.appendMessage(err.message || 'Something went wrong.', false);
      }
    }

    // ─── Chat Submission ────────────────────────────────────────

    async handleChatSubmit(e: Event) {
      e.preventDefault();
      const text = this.input.value.trim();
      if (!text) return;

      this.appendMessage(text, true);
      this.input.value = '';
      this.input.style.height = 'auto';
      if (this.submitBtn) this.submitBtn.disabled = true;

      // Hide chips
      if (this.chipsContainer) {
        this.chipsContainer.style.display = 'none';
      }

      this.showLoading();

      try {
        const lang = this.langSelect?.value || 'auto';
        const res = await fetch('/api/chat', {
          method: 'POST',
          headers: this.getApiHeaders(),
          body: JSON.stringify({ message: text, lang, tab: 'chat' })
        });

        this.removeLoading();

        if (!res.ok) {
          throw new Error(await this.parseError(res));
        }

        const contentType = res.headers.get('Content-Type') || '';
        if (contentType.includes('text/event-stream')) {
          await this.consumeStream(res);
        } else {
          // Fallback for non-streaming responses
          const data = await res.json();
          this.appendMessage(data.answer, false, data.sources);
          this.updateQuota(data.quota);
        }

      } catch (err: any) {
        this.removeLoading();
        this.appendMessage(err.message || 'Something went wrong.', false);
      } finally {
        if (this.submitBtn) this.submitBtn.disabled = false;
        this.input.focus();
      }
    }

    // ─── JD Analysis ────────────────────────────────────────────

    updateJdCharCount() {
      if (!this.jdInput || !this.jdCharCount || !this.jdAnalyzeBtn) return;
      const len = this.jdInput.value.length;
      const formatted = len.toLocaleString();
      this.jdCharCount.textContent = `${formatted} / 6,000`;

      // Enable analyze button if there's enough text
      this.jdAnalyzeBtn.disabled = len < 50;

      // Color the counter
      if (len > 5500) {
        this.jdCharCount.className = 'jd-char-count text-xs text-error';
      } else if (len > 4500) {
        this.jdCharCount.className = 'jd-char-count text-xs text-warning';
      } else {
        this.jdCharCount.className = 'jd-char-count text-xs text-gray-400';
      }
    }

    async handleJdAnalyze() {
      if (!this.jdInput || !this.jdAnalyzeBtn || !this.jdResults) return;

      const text = this.jdInput.value.trim();
      if (text.length < 50) return;

      this.jdAnalyzeBtn.disabled = true;
      this.jdAnalyzeBtn.textContent = '⏳ Analyzing...';
      this.clearElement(this.jdResults);
      this.jdResults.classList.remove('hidden');

      // Show loading in results area
      const loadingEl = document.createElement('div');
      loadingEl.className = 'flex items-center justify-center py-8';
      const dotsContainer = document.createElement('div');
      dotsContainer.className = 'flex space-x-1';
      ['', 'delay-75', 'delay-150'].forEach(delay => {
        const dot = document.createElement('div');
        dot.className = `w-2 h-2 bg-eucalyptus-400 rounded-full animate-bounce ${delay}`;
        dotsContainer.appendChild(dot);
      });
      loadingEl.appendChild(dotsContainer);
      this.jdResults.appendChild(loadingEl);

      try {
        const lang = this.langSelect?.value || 'auto';
        const res = await fetch('/api/chat', {
          method: 'POST',
          headers: this.getApiHeaders(),
          body: JSON.stringify({ message: text, lang, tab: 'jd' })
        });

        if (!res.ok) {
          throw new Error(await this.parseError(res));
        }

        const data = await res.json();
        this.clearElement(this.jdResults);
        this.renderJdResult(data.answer, data.sources);
        this.updateQuota(data.quota);

      } catch (err: any) {
        this.clearElement(this.jdResults);
        this.renderJdError(err.message || 'Analysis failed. Please try again.');
      } finally {
        this.jdAnalyzeBtn.disabled = false;
        this.clearElement(this.jdAnalyzeBtn);
        const icon = document.createElement('span');
        icon.setAttribute('aria-hidden', 'true');
        icon.textContent = '🔍';
        this.jdAnalyzeBtn.appendChild(icon);
        this.jdAnalyzeBtn.appendChild(document.createTextNode(' Analyze Fit'));
      }
    }

    renderJdResult(answer: string, sources: any[] = []) {
      if (!this.jdResults) return;

      // Try to parse structured JSON
      let parsed: any = null;
      try {
        // Strip markdown fences if present
        const cleaned = answer.replace(/^```(?:json)?\s*/i, '').replace(/\s*```$/i, '').trim();
        parsed = JSON.parse(cleaned);
      } catch {
        // Fallback: render as plain text
        this.renderJdResultFallback(answer, sources);
        return;
      }

      const container = document.createElement('div');
      container.className = 'jd-result-card space-y-4 animate-fade-in';

      // ── Score Header ─────────────────────────────────────────
      const scoreSection = document.createElement('div');
      scoreSection.className = 'bg-white dark:bg-dark-elevated rounded-xl border border-gray-200 dark:border-dark-border shadow-subtle p-4';

      // Verdict + Score row
      const topRow = document.createElement('div');
      topRow.className = 'flex items-center justify-between mb-3';

      const verdictBadge = document.createElement('span');
      const score = parsed.score || 0;
      const verdict = parsed.verdict || 'Unknown';
      const verdictColors: Record<string, string> = {
        'Strong Match': 'bg-eucalyptus-100 dark:bg-eucalyptus-900 text-eucalyptus-800 dark:text-eucalyptus-200 border-eucalyptus-300 dark:border-eucalyptus-700',
        'Good Match': 'bg-blue-100 dark:bg-blue-900 text-blue-800 dark:text-blue-200 border-blue-300 dark:border-blue-700',
        'Partial Match': 'bg-amber-100 dark:bg-amber-900 text-amber-800 dark:text-amber-200 border-amber-300 dark:border-amber-700',
        'Not Aligned': 'bg-red-100 dark:bg-red-900 text-red-800 dark:text-red-200 border-red-300 dark:border-red-700',
      };
      verdictBadge.className = `px-3 py-1 rounded-full text-xs font-bold border ${verdictColors[verdict] || verdictColors['Partial Match']}`;
      verdictBadge.textContent = verdict;
      topRow.appendChild(verdictBadge);

      const scoreLabel = document.createElement('span');
      scoreLabel.className = 'text-2xl font-bold text-gray-800 dark:text-gray-200';
      scoreLabel.textContent = `${score}%`;
      topRow.appendChild(scoreLabel);
      scoreSection.appendChild(topRow);

      // Progress bar
      const barBg = document.createElement('div');
      barBg.className = 'w-full h-2.5 bg-gray-100 dark:bg-gray-700 rounded-full overflow-hidden mb-3';
      const barFill = document.createElement('div');
      const barColor = score >= 80 ? 'bg-eucalyptus-500' : score >= 60 ? 'bg-blue-500' : score >= 40 ? 'bg-amber-500' : 'bg-red-500';
      barFill.className = `h-full ${barColor} rounded-full transition-all duration-1000 ease-out`;
      barFill.style.width = '0%';
      barBg.appendChild(barFill);
      scoreSection.appendChild(barBg);
      // Animate bar
      requestAnimationFrame(() => { requestAnimationFrame(() => { barFill.style.width = `${score}%`; }); });

      // Summary
      if (parsed.summary) {
        const summary = document.createElement('p');
        summary.className = 'text-sm text-gray-600 dark:text-gray-400 leading-relaxed';
        summary.textContent = parsed.summary;
        scoreSection.appendChild(summary);
      }
      container.appendChild(scoreSection);

      // ── Match Sections ────────────────────────────────────────
      const sections: Array<{ title: string; icon: string; items: any[]; type: 'match' | 'transfer' | 'gap' }> = [
        { title: 'Matching Qualifications', icon: '\u2705', items: parsed.matches || [], type: 'match' },
        { title: 'Transferable Skills', icon: '\ud83d\udd04', items: parsed.transferable || [], type: 'transfer' },
        { title: 'Gaps / Differences', icon: '\u26a0\ufe0f', items: parsed.gaps || [], type: 'gap' },
      ];

      for (const section of sections) {
        if (section.items.length === 0) continue;

        const sectionEl = document.createElement('div');
        sectionEl.className = 'bg-white dark:bg-dark-elevated rounded-xl border border-gray-200 dark:border-dark-border shadow-subtle';

        const sectionHeader = document.createElement('div');
        sectionHeader.className = 'flex items-center gap-2 px-4 py-2.5 border-b border-gray-100 dark:border-dark-border';
        const icon = document.createElement('span');
        icon.textContent = section.icon;
        sectionHeader.appendChild(icon);
        const title = document.createElement('h5');
        title.className = 'text-xs font-bold text-gray-700 dark:text-gray-300 uppercase tracking-wider';
        title.textContent = section.title;
        sectionHeader.appendChild(title);
        const count = document.createElement('span');
        count.className = 'ml-auto text-xs bg-gray-100 dark:bg-gray-700 text-gray-500 dark:text-gray-400 px-1.5 py-0.5 rounded-full';
        count.textContent = String(section.items.length);
        sectionHeader.appendChild(count);
        sectionEl.appendChild(sectionHeader);

        const list = document.createElement('div');
        list.className = 'divide-y divide-gray-50 dark:divide-dark-border';

        for (const item of section.items) {
          const row = document.createElement('div');
          row.className = 'px-4 py-2.5';

          const skillName = document.createElement('div');
          skillName.className = 'text-sm font-semibold text-gray-800 dark:text-gray-200 mb-0.5';
          skillName.textContent = item.skill || item.requirement || '';
          row.appendChild(skillName);

          const detail = document.createElement('div');
          detail.className = 'text-xs text-gray-500 dark:text-gray-400 leading-relaxed';
          detail.textContent = item.detail || '';
          row.appendChild(detail);

          if (item.source && section.type === 'match') {
            const srcLink = document.createElement('a');
            srcLink.href = item.source;
            srcLink.target = '_blank';
            srcLink.rel = 'noopener noreferrer';
            srcLink.className = 'inline-block mt-1 text-xs text-eucalyptus-600 dark:text-eucalyptus-400 hover:underline';
            srcLink.textContent = '\u{1F517} Source';
            row.appendChild(srcLink);
          }
          list.appendChild(row);
        }
        sectionEl.appendChild(list);
        container.appendChild(sectionEl);
      }

      // ── Recommendation ─────────────────────────────────────────
      if (parsed.recommendation) {
        const recSection = document.createElement('div');
        recSection.className = 'bg-eucalyptus-50 dark:bg-eucalyptus-950 rounded-xl border border-eucalyptus-200 dark:border-eucalyptus-800 p-4';
        const recHeader = document.createElement('div');
        recHeader.className = 'flex items-center gap-2 mb-2';
        const recIcon = document.createElement('span');
        recIcon.textContent = '\ud83d\udca1';
        recHeader.appendChild(recIcon);
        const recTitle = document.createElement('h5');
        recTitle.className = 'text-xs font-bold text-eucalyptus-800 dark:text-eucalyptus-200 uppercase tracking-wider';
        recTitle.textContent = 'Recommendation';
        recHeader.appendChild(recTitle);
        recSection.appendChild(recHeader);
        const recText = document.createElement('p');
        recText.className = 'text-sm text-eucalyptus-700 dark:text-eucalyptus-300 leading-relaxed';
        recText.textContent = parsed.recommendation;
        recSection.appendChild(recText);
        container.appendChild(recSection);
      }

      // ── Sources ──────────────────────────────────────────────
      if (sources && sources.length > 0) {
        const srcDiv = document.createElement('div');
        srcDiv.className = 'px-1';
        const srcLabel = document.createElement('p');
        srcLabel.className = 'text-xs text-gray-400 uppercase tracking-wider font-medium mb-1';
        srcLabel.textContent = 'Portfolio Sources';
        srcDiv.appendChild(srcLabel);
        const srcList = document.createElement('div');
        srcList.className = 'flex flex-wrap gap-1';
        sources.forEach(src => {
          const badge = document.createElement('a');
          badge.href = src.url;
          badge.target = '_blank';
          badge.rel = 'noopener noreferrer';
          badge.className = 'inline-block text-xs bg-gray-100 dark:bg-gray-800 text-gray-500 dark:text-gray-400 px-2 py-0.5 rounded-full hover:bg-gray-200 dark:hover:bg-gray-700 transition-colors';
          badge.textContent = src.title || 'Source';
          srcList.appendChild(badge);
        });
        srcDiv.appendChild(srcList);
        container.appendChild(srcDiv);
      }

      this.jdResults.appendChild(container);
    }

    renderJdResultFallback(answer: string, sources: any[] = []) {
      if (!this.jdResults) return;

      const container = document.createElement('div');
      container.className = 'jd-result-card bg-white dark:bg-dark-elevated rounded-xl border border-gray-200 dark:border-dark-border shadow-subtle p-4 space-y-3 animate-fade-in';

      const header = document.createElement('div');
      header.className = 'flex items-center gap-2 pb-2 border-b border-gray-100 dark:border-dark-border';
      const headerIcon = document.createElement('span');
      headerIcon.className = 'text-lg';
      headerIcon.textContent = '\ud83d\udcca';
      header.appendChild(headerIcon);
      const headerTitle = document.createElement('h4');
      headerTitle.className = 'font-bold text-sm text-gray-800 dark:text-gray-200';
      headerTitle.textContent = 'Fit Analysis Result';
      header.appendChild(headerTitle);
      container.appendChild(header);

      const content = document.createElement('div');
      content.className = 'text-sm text-gray-700 dark:text-gray-300 whitespace-pre-wrap leading-relaxed';
      content.textContent = answer;
      container.appendChild(content);

      if (sources && sources.length > 0) {
        const srcDiv = document.createElement('div');
        srcDiv.className = 'pt-2 border-t border-gray-100 dark:border-dark-border';
        const srcLabel = document.createElement('p');
        srcLabel.className = 'text-xs text-gray-400 uppercase tracking-wider font-medium mb-1';
        srcLabel.textContent = 'Sources';
        srcDiv.appendChild(srcLabel);
        const srcList = document.createElement('div');
        srcList.className = 'flex flex-wrap gap-1';
        sources.forEach(src => {
          const badge = document.createElement('a');
          badge.href = src.url;
          badge.target = '_blank';
          badge.rel = 'noopener noreferrer';
          badge.className = 'inline-block text-xs bg-eucalyptus-50 dark:bg-eucalyptus-950 text-eucalyptus-700 dark:text-eucalyptus-300 px-2 py-0.5 rounded-full hover:bg-eucalyptus-100 transition-colors';
          badge.textContent = src.title || 'Source';
          srcList.appendChild(badge);
        });
        srcDiv.appendChild(srcList);
        container.appendChild(srcDiv);
      }

      this.jdResults.appendChild(container);
    }

    renderJdError(message: string) {
      if (!this.jdResults) return;
      const errorEl = document.createElement('div');
      errorEl.className = 'bg-error-light dark:bg-red-900/20 text-error dark:text-red-400 p-3 rounded-lg text-sm animate-fade-in';
      errorEl.textContent = message;
      this.jdResults.appendChild(errorEl);
    }

    // ─── Message Rendering ──────────────────────────────────────

    createMessageElement(text: string, isUser: boolean, sources: any[] = []) {
      const div = document.createElement('div');

      if (isUser) {
        div.className = 'message user bg-eucalyptus-600 text-white p-3 rounded-lg rounded-tr-none shadow-sm text-sm ml-auto max-w-88 self-end mb-3 animate-fade-in';
        div.textContent = text;
      } else {
        div.className = 'message ai bg-white dark:bg-dark-elevated p-3 rounded-lg rounded-tl-none shadow-subtle text-sm dark:text-gray-200 border border-gray-100 dark:border-dark-border mr-auto max-w-88 mb-3 animate-fade-in';

        const textSpan = document.createElement('span');
        textSpan.className = 'whitespace-pre-wrap';
        textSpan.textContent = text;
        div.appendChild(textSpan);

        if (sources && sources.length > 0) {
          const sourceDiv = document.createElement('div');
          sourceDiv.className = 'mt-2 pt-2 border-t border-gray-100 dark:border-dark-border';

          const srcLabel = document.createElement('p');
          srcLabel.className = 'text-xs text-gray-400 uppercase tracking-wider font-medium mb-1';
          srcLabel.textContent = 'Sources';
          sourceDiv.appendChild(srcLabel);

          const srcList = document.createElement('div');
          srcList.className = 'flex flex-wrap gap-1';
          sources.forEach(src => {
            const badge = document.createElement('a');
            badge.href = src.url;
            badge.target = '_blank';
            badge.rel = 'noopener noreferrer';
            badge.className = 'inline-block text-xs bg-eucalyptus-50 dark:bg-eucalyptus-950 text-eucalyptus-700 dark:text-eucalyptus-300 px-2 py-0.5 rounded-full hover:bg-eucalyptus-100 transition-colors';
            badge.textContent = src.title || 'Source';
            srcList.appendChild(badge);
          });
          sourceDiv.appendChild(srcList);
          div.appendChild(sourceDiv);
        }
      }
      return div;
    }

    appendMessage(text: string, isUser: boolean, sources: any[] = []) {
      const msgNode = this.createMessageElement(text, isUser, sources);
      this.messagesEl.appendChild(msgNode);
      this.scrollToBottom();
    }

    showLoading() {
      const div = document.createElement('div');
      div.className = 'loading-indicator message ai bg-white dark:bg-dark-elevated p-3 rounded-lg rounded-tl-none shadow-subtle text-sm w-16 mb-3 animate-fade-in';

      const container = document.createElement('div');
      container.className = 'flex space-x-1 justify-center';

      ['', 'delay-75', 'delay-150'].forEach(delay => {
        const dot = document.createElement('div');
        dot.className = `w-2 h-2 bg-eucalyptus-400 rounded-full animate-bounce ${delay}`;
        container.appendChild(dot);
      });

      div.appendChild(container);
      this.messagesEl.appendChild(div);
      this.scrollToBottom();
    }

    removeLoading() {
      const el = this.messagesEl.querySelector('.loading-indicator');
      el?.remove();
    }

    scrollToBottom() {
      this.messagesEl.scrollTop = this.messagesEl.scrollHeight;
    }

    // ─── SSE Stream Consumer ─────────────────────────────────────

    async consumeStream(res: Response) {
      if (!res.body) {
        this.appendMessage('Stream unavailable.', false);
        return;
      }

      // Create the AI message bubble with empty text span
      const bubble = document.createElement('div');
      bubble.className = 'message ai bg-white dark:bg-dark-elevated p-3 rounded-lg rounded-tl-none shadow-subtle text-sm dark:text-gray-200 border border-gray-100 dark:border-dark-border mr-auto max-w-88 mb-3 animate-fade-in';
      const textSpan = document.createElement('span');
      textSpan.className = 'whitespace-pre-wrap';
      bubble.appendChild(textSpan);
      this.messagesEl.appendChild(bubble);
      this.scrollToBottom();

      let sources: any[] = [];
      const reader = res.body.getReader();
      const decoder = new TextDecoder();
      let buffer = '';

      while (true) {
        const { done, value } = await reader.read();
        if (done) break;

        buffer += decoder.decode(value, { stream: true });
        const segments = buffer.split('\n\n');
        buffer = segments.pop() || ''; // Keep incomplete segment

        for (const segment of segments) {
          if (!segment.trim()) continue;

          let eventType = '';
          let eventData = '';

          for (const line of segment.split('\n')) {
            if (line.startsWith('event: ')) eventType = line.slice(7).trim();
            else if (line.startsWith('data: ')) eventData = line.slice(6).trim();
          }

          if (!eventData) continue;

          try {
            const parsed = JSON.parse(eventData);

            if (eventType === 'meta') {
              sources = parsed.sources || [];
              this.updateQuota(parsed.quota);
            } else if (eventType === 'delta' && parsed.text) {
              textSpan.textContent += parsed.text;
              this.scrollToBottom();
            } else if (eventType === 'error') {
              textSpan.textContent += '\n⚠️ ' + (parsed.error || 'Stream error');
            }
          } catch {
            // Skip malformed events
          }
        }
      }

      // Append sources after streaming completes
      if (sources.length > 0) {
        const sourceDiv = document.createElement('div');
        sourceDiv.className = 'mt-2 pt-2 border-t border-gray-100 dark:border-dark-border';

        const srcLabel = document.createElement('p');
        srcLabel.className = 'text-xs text-gray-400 uppercase tracking-wider font-medium mb-1';
        srcLabel.textContent = 'Sources';
        sourceDiv.appendChild(srcLabel);

        const srcList = document.createElement('div');
        srcList.className = 'flex flex-wrap gap-1';
        sources.forEach((src: any) => {
          const badge = document.createElement('a');
          badge.href = src.url;
          badge.target = '_blank';
          badge.rel = 'noopener noreferrer';
          badge.className = 'inline-block text-xs bg-eucalyptus-50 dark:bg-eucalyptus-950 text-eucalyptus-700 dark:text-eucalyptus-300 px-2 py-0.5 rounded-full hover:bg-eucalyptus-100 transition-colors';
          badge.textContent = src.title || 'Source';
          srcList.appendChild(badge);
        });
        sourceDiv.appendChild(srcList);
        bubble.appendChild(sourceDiv);
      }
    }

    async parseError(res: Response): Promise<string> {
      const codeMessages: Record<string, string> = {
        'RATE_LIMIT': 'Too many requests \u2014 please wait a moment.',
        'INPUT_EMPTY': 'Please type a message first.',
        'INPUT_TOO_LONG': 'Message is too long.',
        'CORPUS_LOAD_FAILED': 'Knowledge base unavailable. Try again later.',
        'OPENAI_KEY_MISSING': 'AI service is not configured.',
        'OPENAI_UPSTREAM_ERROR': 'AI service temporarily unavailable.',
        'AI_BILLING_EXHAUSTED': '\ud83d\udd27 AI assistant is temporarily on a break. The deterministic answers (Contact, Certs, Role, Projects) still work!',
        'AI_QUOTA_EXCEEDED': '\ud83d\udcca AI assistant has reached its daily limit. Please try again tomorrow.',
        'AI_RATE_LIMITED': '\u23f3 Too many requests \u2014 please wait a moment and retry.',
        'AI_SERVICE_DOWN': '\u26a0\ufe0f AI assistant is temporarily unavailable. Please try again shortly.',
        'AI_UNREACHABLE': '\ud83d\udd0c Unable to reach the AI service. Please check back later.',
      };
      try {
        const errData = await res.json();
        return codeMessages[errData.code] || errData.error || 'Something went wrong.';
      } catch {
        return 'Something went wrong.';
      }
    }
  }

  function initChatWidgets() {
    document.querySelectorAll('[data-chat-widget]').forEach(el => {
      const widgetEl = el as HTMLElement & { __mamChatWidgetInit?: boolean };
      if (widgetEl.__mamChatWidgetInit) return;
      widgetEl.__mamChatWidgetInit = true;
      new ChatWidget(widgetEl);
    });
  }

  // Initialize once on first load + again after client-side route transitions.
  document.addEventListener('DOMContentLoaded', initChatWidgets);
  document.addEventListener('astro:page-load', initChatWidgets);
</script>

