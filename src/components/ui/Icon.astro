---
import {
  ArrowRight,
  ChartColumn,
  Bot,
  BookOpen,
  Brain,
  BriefcaseBusiness,
  Camera,
  CircleCheck,
  Circle,
  CreditCard,
  ClipboardList,
  CodeXml,
  Cog,
  Construction,
  Cookie,
  Cpu,
  Flag,
  Database,
  FlaskConical,
  Globe,
  Gauge,
  HardDrive,
  Headphones,
  Landmark,
  Lightbulb,
  Lock,
  Mail,
  Music2,
  Palette,
  Play,
  Printer,
  Radio,
  Recycle,
  Rocket,
  Scale,
  Search,
  Settings2,
  ShoppingCart,
  Sparkles,
  Target,
  WandSparkles,
  Zap
} from '@lucide/astro';

interface Props {
  name: string;
  class?: string;
  strokeWidth?: number;
}

const { name, class: className = 'h-5 w-5', strokeWidth = 1.9 } = Astro.props;

const iconMap = {
  'arrow-right': ArrowRight,
  'bar-chart-3': ChartColumn,
  'book-open': BookOpen,
  brain: Brain,
  briefcase: BriefcaseBusiness,
  bot: Bot,
  camera: Camera,
  cart: ShoppingCart,
  'check-circle': CircleCheck,
  circle: Circle,
  clipboard: ClipboardList,
  code: CodeXml,
  cog: Cog,
  cookie: Cookie,
  'credit-card': CreditCard,
  construction: Construction,
  cpu: Cpu,
  database: Database,
  flag: Flag,
  flask: FlaskConical,
  globe: Globe,
  gauge: Gauge,
  harddrive: HardDrive,
  headphones: Headphones,
  landmark: Landmark,
  lightbulb: Lightbulb,
  lock: Lock,
  mail: Mail,
  music: Music2,
  palette: Palette,
  play: Play,
  printer: Printer,
  radio: Radio,
  recycle: Recycle,
  rocket: Rocket,
  scale: Scale,
  search: Search,
  settings: Settings2,
  sparkles: Sparkles,
  target: Target,
  wand: WandSparkles,
  zap: Zap,
  // Legacy emoji aliases used in data JSON
  '🧠': Brain,
  '💼': BriefcaseBusiness,
  '🎵': Music2,
  '🔍': Search,
  '🚀': Rocket,
  '⚡': Zap,
  '🌍': Globe,
  '🟢': Circle,
  '✅': CircleCheck,
  '🚧': Construction,
  '🔬': FlaskConical,
  '🦀': CodeXml,
  '🌐': Globe,
  '⚖️': Scale,
  '🧬': Sparkles,
  '⚛️': Cpu,
  '📚': BookOpen,
  '💾': HardDrive,
  '📊': ChartColumn,
  '📐': Target,
  '🎯': Target,
  '📋': ClipboardList,
  '📖': BookOpen,
  '🔒': Lock,
  '🏗️': Cog,
  '💡': Lightbulb,
  '🔴': Circle,
  '🛒': ShoppingCart,
  '🖨️': Printer,
  '💳': CreditCard,
  '🇩🇪': Flag,
  '🛍️': ShoppingCart,
  '🎨': Palette,
  '♻️': Recycle,
  '⚙️': Settings2,
  '📡': Radio,
  '🎧': Headphones,
  '▶️': Play,
  '🤖': Bot,
  '🎶': Music2,
  '🏛️': Landmark,
  '📸': Camera,
  '🟣': Circle
} as const;

const IconComponent = iconMap[name as keyof typeof iconMap] ?? Circle;
---

<IconComponent class={className} stroke-width={strokeWidth} aria-hidden="true" focusable="false" />
