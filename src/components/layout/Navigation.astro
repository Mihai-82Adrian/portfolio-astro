---
/**
 * Navigation Component
 *
 * Main navigation menu with active page highlighting.
 * Supports both desktop (horizontal) and mobile (vertical) layouts.
 *
 * @component
 */

interface Props {
  currentPath?: string;
  mobile?: boolean;
  basePath?: string;
}

const { currentPath = '', mobile = false, basePath = '' } = Astro.props;

// Tools, Blog, Projects, and Now are language-independent and link to main version
// Other pages use language-specific paths
const navigationLinks = [
  { href: `${basePath}/`, label: 'Home' },
  { href: `/tools`, label: 'Tools' }, // Global hub route
  { href: `${basePath}/about`, label: 'About' },
  { href: `${basePath}/experience`, label: 'Experience' },
  { href: `/projects`, label: 'Projects' }, // Always main version
  { href: `${basePath}/services`, label: 'Services' }, // i18n-aware (DE/EN/RO)
  { href: `/blog`, label: 'Blog' }, // Always main version
  { href: `/now`, label: 'Now' }, // Always main version
  // Contact info is inline on homepage at #contact
];

/**
 * Check if a link is active based on current path
 */
const normalizePath = (path: string): string => {
  if (!path) return '/';
  const normalized = path.replace(/\/+$/, '');
  return normalized === '' ? '/' : normalized;
};

const isActive = (href: string): boolean => {
  const current = normalizePath(currentPath);
  const target = normalizePath(href);

  if (target === '/') {
    return current === '/';
  }
  return current === target || current.startsWith(`${target}/`);
};
---

<nav class:list={[mobile ? 'mobile-nav' : 'desktop-nav']} aria-label="Main navigation">
  <ul
    class:list={[
      mobile
        ? 'flex flex-col space-y-2'
        : 'flex items-center space-x-1 lg:space-x-2',
    ]}
  >
    {
      navigationLinks.map((link) => {
        const active = isActive(link.href);
        return (
          <li>
            <a
              href={link.href}
              data-nav-href={link.href}
              class:list={[
                'nav-link',
                mobile ? 'nav-link-mobile' : 'nav-link-desktop',
                active && 'nav-link-active',
              ]}
              aria-current={active ? 'page' : undefined}
            >
              {link.label}
            </a>
          </li>
        );
      })
    }
  </ul>
</nav>

<script is:inline>
  (() => {
    const normalizePath = (path) => {
      if (!path) return '/';
      const normalized = path.replace(/\/+$/, '');
      return normalized === '' ? '/' : normalized;
    };

    const matches = (currentPath, href) => {
      const current = normalizePath(currentPath);
      const target = normalizePath(href);
      if (target === '/') return current === '/';
      return current === target || current.startsWith(`${target}/`);
    };

    const syncActiveNav = () => {
      const currentPath = window.location.pathname;
      document.querySelectorAll('a.nav-link[data-nav-href]').forEach((el) => {
        const href = el.getAttribute('data-nav-href') || '/';
        const active = matches(currentPath, href);
        el.classList.toggle('nav-link-active', active);
        if (active) el.setAttribute('aria-current', 'page');
        else el.removeAttribute('aria-current');
      });
    };

    syncActiveNav();
    document.addEventListener('astro:page-load', syncActiveNav);
  })();
</script>

<style>
@reference "../../styles/global.css";
  /* Base navigation link styles */
  .nav-link {
    position: relative;
    font-weight: 500;
    text-decoration: none !important;
    transition: all var(--transition-fast) ease-in-out;
    @apply rounded-full;
  }
  .nav-link:focus-visible { outline: none; @apply ring-2 ring-eucalyptus-500 ring-offset-2; }

  /* Desktop navigation links */
  .nav-link-desktop {
    @apply px-4 py-2 text-sm rounded-full;
    @apply text-text-secondary-light hover:text-eucalyptus-800 hover:bg-eucalyptus-50;
    @apply dark:text-text-secondary-dark dark:hover:text-eucalyptus-200 dark:hover:bg-eucalyptus-500/20;
  }

  /* Mobile navigation links */
  .nav-link-mobile {
    @apply block px-4 py-3 text-lg rounded-lg;
    @apply text-text-primary-light hover:bg-eucalyptus-50;
    @apply dark:text-text-primary-dark dark:hover:bg-dark-elevated;
  }

  /* Active link styles - Base */
  .nav-link-active {
    @apply text-eucalyptus-800 dark:text-eucalyptus-200 font-semibold;
  }

  /* Desktop active state - subtle background pill */
  .desktop-nav .nav-link-active {
    @apply bg-eucalyptus-500/15;
    @apply dark:bg-eucalyptus-500/20;
  }

  /* Mobile active indicator */
  .mobile-nav .nav-link-active {
    @apply bg-eucalyptus-50 dark:bg-eucalyptus-900;
    @apply border-l-4 border-eucalyptus-600 dark:border-eucalyptus-400;
  }

  .nav-link:hover,
  .nav-link:focus-visible,
  .nav-link:visited {
    text-decoration: none !important;
  }
</style>
