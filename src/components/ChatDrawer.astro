---
/**
 * ChatDrawer Component
 *
 * Global accessible drawer/modal for the AI Chat.
 * Implements WAI-ARIA dialog pattern (role="dialog", modal, focus trap).
 *
 * Properties:
 * - Triggers via 'chat:toggle' event on window
 * - Manages focus return
 * - Handles Escape key
 * - Animates slide-in
 */

import ChatWidget from './ChatWidget.astro';
---

<div
  id="chat-drawer-backdrop"
  class="fixed inset-0 z-40 bg-black/50 backdrop-blur-sm hidden opacity-0 transition-opacity duration-300"
  aria-hidden="true"
></div>

<div
  id="chat-drawer"
  role="dialog"
  aria-modal="true"
  aria-labelledby="chat-drawer-title"
  class="fixed z-50 bg-white dark:bg-gray-800 shadow-2xl transition-transform duration-300 ease-in-out transform translate-y-full md:translate-y-0 md:translate-x-full
         bottom-0 left-0 right-0 h-5/6 rounded-t-2xl
         md:top-0 md:bottom-0 md:right-0 md:left-auto md:h-full md:w-112 md:rounded-l-2xl md:rounded-tr-none
         flex flex-col border-l border-gray-200 dark:border-gray-700 hidden"
>
  <!-- Screen Reader Title -->
  <h2 id="chat-drawer-title" class="sr-only">Ask Mihai · AI Chat Window</h2>

  <ChatWidget class="h-full w-full" id="drawer-chat-widget">
    <button
      slot="header-actions"
      id="chat-drawer-close"
      class="p-1.5 text-white/80 hover:text-white hover:bg-white/10 rounded-lg transition-colors focus:ring-2 focus:ring-white"
      aria-label="Close AI Chat"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </ChatWidget>
</div>

<script>
  (() => {
    if ((window as any).__mamChatDrawerInit) return;
    (window as any).__mamChatDrawerInit = true;

    let isOpen = false;
    let lastFocusedElement: HTMLElement | null = null;

    const getEls = () => {
      const backdrop = document.getElementById('chat-drawer-backdrop');
      const drawer = document.getElementById('chat-drawer');
      const closeBtn = document.getElementById('chat-drawer-close');
      return { backdrop, drawer, closeBtn };
    };

    function openDrawer(triggerElement?: HTMLElement) {
      const { backdrop, drawer, closeBtn } = getEls();
      if (!backdrop || !drawer || isOpen) return;

      isOpen = true;
      lastFocusedElement = triggerElement || (document.activeElement as HTMLElement);

      backdrop.classList.remove('hidden');
      drawer.classList.remove('hidden');
      void drawer.offsetWidth;
      backdrop.classList.remove('opacity-0');
      drawer.classList.remove('translate-y-full', 'md:translate-x-full');
      document.body.style.overflow = 'hidden';

      setTimeout(() => {
        const input = drawer.querySelector('textarea.chat-input') as HTMLTextAreaElement | null;
        if (input) input.focus();
        else (closeBtn as HTMLElement | null)?.focus();
      }, 100);
    }

    function closeDrawer() {
      const { backdrop, drawer } = getEls();
      if (!backdrop || !drawer || !isOpen) return;

      isOpen = false;
      backdrop.classList.add('opacity-0');
      drawer.classList.add('translate-y-full', 'md:translate-x-full');

      setTimeout(() => {
        backdrop.classList.add('hidden');
        drawer.classList.add('hidden');
        document.body.style.overflow = '';
        if (lastFocusedElement) {
          lastFocusedElement.focus();
          lastFocusedElement = null;
        }
      }, 300);
    }

    window.addEventListener('chat:toggle', (e: Event) => {
      const customEvent = e as CustomEvent;
      const trigger = customEvent.detail?.trigger as HTMLElement | undefined;
      if (isOpen) closeDrawer();
      else openDrawer(trigger);
    });

    window.addEventListener('chat:open', (e: Event) => {
      const customEvent = e as CustomEvent;
      openDrawer(customEvent.detail?.trigger as HTMLElement | undefined);
    });

    window.addEventListener('chat:close', closeDrawer);

    document.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      if (target.closest('#chat-drawer-close') || target.id === 'chat-drawer-backdrop') {
        closeDrawer();
      }
    });

    document.addEventListener('keydown', (e) => {
      if (!isOpen) return;

      if (e.key === 'Escape') {
        closeDrawer();
        return;
      }

      if (e.key !== 'Tab') return;
      const { drawer } = getEls();
      if (!drawer) return;

      const focusableEls = drawer.querySelectorAll('a[href], button, textarea, input[type="text"], input[type="radio"], input[type="checkbox"], select');
      if (!focusableEls.length) return;

      const firstEl = focusableEls[0] as HTMLElement;
      const lastEl = focusableEls[focusableEls.length - 1] as HTMLElement;

      if (e.shiftKey) {
        if (document.activeElement === firstEl) {
          lastEl.focus();
          e.preventDefault();
        }
      } else if (document.activeElement === lastEl) {
        firstEl.focus();
        e.preventDefault();
      }
    });
  })();
</script>
