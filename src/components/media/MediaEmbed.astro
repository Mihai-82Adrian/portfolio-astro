---
import type { ImageMetadata } from 'astro';

interface Props {
  embedUrl: string;
  title: string;
  allow?: string;
  orientation?: 'landscape' | 'portrait';
  type?: 'youtube' | 'spotify' | 'other';
  poster?: ImageMetadata | string;
}

const { embedUrl, title, allow, orientation = 'landscape', type = 'other', poster } = Astro.props;

const isSafeEmbed =
  embedUrl.startsWith('https://open.spotify.com/embed/') ||
  embedUrl.startsWith('https://www.youtube.com/embed/');
const isSpotify = embedUrl.startsWith('https://open.spotify.com/embed/');
const frameWrapperClass =
  orientation === 'portrait'
    ? 'mx-auto aspect-[9/16] w-full max-w-none'
    : 'h-[320px] w-full sm:h-[352px]';

const frameAllow =
  allow ??
  'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share';

const resolvedPoster =
  typeof poster === 'string'
    ? poster
    : poster?.src;
const hasPoster = Boolean(resolvedPoster);
const placeholderStyle = hasPoster
  ? `background-image: url('${resolvedPoster}'); background-size: cover; background-position: center;`
  : undefined;
---

{isSafeEmbed ? (
  <div class="relative overflow-hidden rounded-xl border bg-white shadow-subtle dark:bg-dark-elevated" style="border-color: color-mix(in srgb, var(--color-eucalyptus-500) 34%, transparent);">
    <div class={frameWrapperClass}>
      <!--
        Click-to-load facade: no iframe is injected until the user explicitly
        clicks the placeholder. This prevents third-party cookies (Spotify
        sp_t / sp_landing) from being set without user interaction, satisfying
        GDPR requirements. The MediaGallery script handles the click → iframe swap.
      -->
      <button
        type="button"
        class="embed-pending group relative h-full w-full flex flex-col items-center justify-center gap-3 rounded-xl cursor-pointer border-0 bg-light-surface dark:bg-dark-surface motion-safe:transition-colors motion-safe:duration-200 hover:bg-eucalyptus-50 dark:hover:bg-eucalyptus-950/40 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-eucalyptus-500 focus-visible:ring-offset-2"
        data-embed-src={embedUrl}
        data-embed-title={title}
        data-embed-allow={frameAllow}
        data-embed-type={type}
        aria-label={`Click to load ${isSpotify ? 'Spotify' : 'YouTube'} player: ${title}`}
        style={placeholderStyle}
      >
        {hasPoster && <span class="absolute inset-0 z-0 bg-black/40"></span>}
        {isSpotify ? (
          <!-- Spotify icon -->
          <svg class="relative z-10 w-10 h-10 motion-safe:transition-transform motion-safe:duration-200 group-hover:scale-110" viewBox="0 0 24 24" fill="#1DB954" aria-hidden="true">
            <path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.419 1.56-.299.421-1.02.599-1.559.3z"/>
          </svg>
        ) : (
          <!-- YouTube icon -->
          <svg class="relative z-10 w-10 h-10 motion-safe:transition-transform motion-safe:duration-200 group-hover:scale-110" viewBox="0 0 24 24" fill="#FF0000" aria-hidden="true">
            <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
          </svg>
        )}
        <span class="relative z-10 text-sm font-medium text-white">{title}</span>
        <span class="relative z-10 text-xs text-white/90">
          Click to load player
        </span>
      </button>
    </div>
  </div>
) : (
  <div class="rounded-xl border border-dashed border-warning/60 bg-warning/10 p-4 text-sm text-warning">
    Embed source unavailable.
  </div>
)}
