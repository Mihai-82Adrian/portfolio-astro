---
interface Props {
  embedUrl: string;
  title: string;
  allow?: string;
}

const { embedUrl, title, allow } = Astro.props;

const isSafeEmbed =
  embedUrl.startsWith('https://open.spotify.com/embed/') ||
  embedUrl.startsWith('https://www.youtube.com/embed/');
const isSpotifyEmbed = embedUrl.startsWith('https://open.spotify.com/embed/');
const frameWrapperClass = isSpotifyEmbed ? 'h-[352px] w-full' : 'aspect-video w-full';

const frameAllow =
  allow ??
  'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share';
---

{isSafeEmbed ? (
  <div class="relative overflow-hidden rounded-xl border border-eucalyptus-200/60 bg-white shadow-subtle dark:border-eucalyptus-800/70 dark:bg-dark-elevated">
    <div class={frameWrapperClass}>
      <iframe
        class="h-full w-full"
        style="border:0"
        src={embedUrl}
        title={title}
        loading="lazy"
        allowfullscreen
        allow={frameAllow}
      ></iframe>
    </div>
  </div>
) : (
  <div class="rounded-xl border border-dashed border-warning/60 bg-warning/10 p-4 text-sm text-warning">
    Embed source unavailable.
  </div>
)}
