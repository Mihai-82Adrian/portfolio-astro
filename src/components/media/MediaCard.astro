---
import type { MediaItem, MediaLang } from '../../data/media';
import MediaEmbed from './MediaEmbed.astro';

interface Props {
  item: MediaItem;
  lang?: MediaLang;
}

const { item, lang = 'en' } = Astro.props;

const displayTitle = item.localeLabels?.[lang] ?? item.title;
const typeLabelMap: Record<MediaItem['type'], string> = {
  youtube_playlist: 'YouTube Playlist',
  youtube_video: 'YouTube Video',
  spotify_artist: 'Spotify Artist',
  spotify_playlist: 'Spotify Playlist',
  spotify_track: 'Spotify Track',
};
const typeLabel = typeLabelMap[item.type];
const isPromoShorts = item.tags.includes('promo-shorts');
const layout = isPromoShorts ? 'portrait' : 'landscape';
---

<article
  class="media-card space-y-3"
  data-media-card
  data-featured={item.featured ? 'true' : 'false'}
  data-platform={item.type.startsWith('spotify') ? 'spotify' : 'youtube'}
  data-tags={item.tags.join(',')}
  data-layout={layout}
>
  <MediaEmbed embedUrl={item.embedUrl} title={displayTitle} orientation={layout} />
  <header class="space-y-1">
    <div class="flex items-center gap-2 text-xs">
      <span class="rounded-full bg-eucalyptus-100 px-2 py-1 font-medium text-eucalyptus-800 dark:bg-eucalyptus-900 dark:text-eucalyptus-200">{typeLabel}</span>
      {item.featured && <span class="rounded-full bg-info/15 px-2 py-1 font-medium text-info">Featured</span>}
    </div>
    <h3 class="text-base font-semibold text-text-primary-light dark:text-text-primary-dark">{displayTitle}</h3>
    {item.description && (
      <p class="text-sm text-text-secondary-light dark:text-text-secondary-dark">{item.description}</p>
    )}
    <a href={item.url} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1 text-sm font-medium text-eucalyptus-700 underline-offset-2 hover:underline dark:text-eucalyptus-300" aria-label={`Open source for ${displayTitle}`}>
      Open source link
    </a>
  </header>
</article>
