---
/**
 * Base Layout Component
 *
 * Provides the foundation for all pages:
 * - HTML structure with proper meta tags
 * - Global CSS imports
 * - Theme initialization (prevents flash)
 * - Responsive viewport settings
 * - SEO-friendly defaults
 * - Multilingual support (DE/EN/RO)
 * - hreflang tags for language variants
 * - Pagefind indexing (data-pagefind-body)
 */

import { ViewTransitions } from 'astro:transitions';
import { themeScript } from '@/utils/theme';
import Header from '@components/layout/Header.astro';
import Footer from '@components/layout/Footer.astro';
import type { Language } from '@utils/i18n';
import { getAlternateUrls } from '@utils/i18n';
import '@/styles/global.css';
import tokens from '@/data/design-tokens.json';
import ChatDrawer from '@components/ChatDrawer.astro';
import CookieConsent from '@components/common/CookieConsent.astro';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  canonicalURL?: string;
  lang?: Language;
  noindex?: boolean;
  structuredData?: Record<string, any>;
}

const {
  title = 'Mihai Adrian Mateescu - Finanzbuchhalter Portfolio',
  description = 'Finanzbuchhalter mit Erfahrung in Buchhaltung, Finanzmanagement und Steuerberatung. Aktuell in Weiterbildung zum Bilanzbuchhalter (IHK).',
  ogImage = '/images/me.webp',
  canonicalURL, // NOTE: we will compute a stable default below
  lang: langProp,
  noindex = false,
  structuredData
} = Astro.props;

const siteTitle = 'Mihai Adrian Mateescu';

// Prefer Astro.site (from astro.config.mjs `site:`), fallback to hard-coded
const siteUrl =
  (Astro.site?.href?.replace(/\/$/, '') ?? 'https://me-mateescu.de');

const currentPath = Astro.url.pathname;

// Your rule: Blog is EN-only (even though it lives at /blog without /en prefix)
const isBlog = currentPath === '/blog' || currentPath.startsWith('/blog/');

// Infer language from pathname if not explicitly passed via props
const inferredLang: Language =
  isBlog ? 'en' :
  currentPath.startsWith('/en') ? 'en' :
  currentPath.startsWith('/ro') ? 'ro' :
  'de';

const lang: Language = langProp ?? inferredLang;

// Canonical should be stable (production origin), allow override from props
const canonicalHref = canonicalURL ?? new URL(currentPath, siteUrl).href;

const fullTitle = title === siteTitle ? title : `${title} | ${siteTitle}`;
const fullImageUrl = ogImage.startsWith('http') ? ogImage : `${siteUrl}${ogImage}`;

// Generate alternate language URLs
// For EN-only blog: emit only en + x-default to avoid claiming translations
const alternateUrls = isBlog
  ? { en: canonicalHref, 'x-default': canonicalHref }
  : getAlternateUrls(currentPath, siteUrl);

const ogLocale =
  lang === 'de' ? 'de_DE' :
  lang === 'en' ? 'en_GB' :
  'ro_RO';

// Default structured data (Person schema)
const defaultStructuredData = {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Mihai Adrian Mateescu",
  "givenName": "Mihai Adrian",
  "familyName": "Mateescu",
  "jobTitle": lang === 'de' ? 'Finanzbuchhalter' : lang === 'en' ? 'Financial Accountant' : 'Contabil Financiar',
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Seevetal",
    "postalCode": "21218",
    "streetAddress": "Bahnhofstraße 65b",
    "addressCountry": "DE"
  },
  "email": "mihai.mateescu@web.de",
  "telephone": "+491704740121",
  "url": siteUrl,
  "sameAs": [
    "https://www.linkedin.com/in/mihai-adrian-mateescu",
    "https://profit-minds.de"
  ],
  "knowsLanguage": ["de", "en", "ro"]
};
---

<!doctype html>
<html lang={lang} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary Meta Tags -->
    <title>{fullTitle}</title>
    <meta name="title" content={fullTitle} />
    <meta name="description" content={description} />
    <meta name="author" content="Mihai Adrian Mateescu" />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    {!noindex && <meta name="robots" content="index, follow" />}

    <!-- Canonical URL -->
    <link rel="canonical" href={canonicalHref} />

    <!-- Alternate Language Links (hreflang) -->
    {Object.entries(alternateUrls).map(([hreflang, url]) => (
      <link rel="alternate" hreflang={hreflang} href={url} />
    ))}

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalHref} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={fullImageUrl} />
    <meta property="og:locale" content={ogLocale} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalHref} />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={fullImageUrl} />

    <!-- Favicons -->
    <link rel="icon" href="/images/favicon.ico" sizes="any" />
    <link rel="icon" href="/images/favicon.svg" type="image/svg+xml" />
    <link rel="icon" type="image/png" sizes="32x32" href="/images/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/images/favicon-16x16.png" />
    <link rel="apple-touch-icon" href="/images/apple-touch-icon.png" />
    <link rel="mask-icon" href="/images/safari-pinned-tab.svg" color={tokens.colors.eucalyptus[500]} />

    <!-- Theme Color (matches eucalyptus green) -->
    <meta name="theme-color" content={tokens.colors.eucalyptus[500]} />
    <meta name="msapplication-TileColor" content={tokens.colors.eucalyptus[500]} />

    <!-- Web Manifest -->
    <link rel="manifest" href="/site.webmanifest" />

    <!-- Structured Data (JSON-LD) -->
    <script
      type="application/ld+json"
      set:html={JSON.stringify(structuredData || defaultStructuredData)}
    />

    <!-- KaTeX CSS for math equations (self-hosted for privacy and performance) -->
    <link rel="stylesheet" href="/katex/katex.min.css" />

    <!-- Fonts: Inter + Playfair Display + JetBrains Mono -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Playfair+Display:wght@400;700&family=JetBrains+Mono:wght@400;500;600&display=swap"
      rel="stylesheet"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link
        href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Playfair+Display:wght@400;700&family=JetBrains+Mono:wght@400;500;600&display=swap"
        rel="stylesheet"
      />
    </noscript>

    <!-- Theme initialization (inline to prevent flash) -->
    <script is:inline set:html={themeScript} />

    <!-- View Transitions: SPA-like navigation -->
    <ViewTransitions />
  </head>

  <body class="min-h-screen bg-light-bg dark:bg-dark-bg text-text-primary-light dark:text-text-primary-dark antialiased transition-colors duration-300">
    <!-- Skip to main content link (WCAG 2.2 AAA) -->
    <a
      href="#main-content"
      class="skip-link sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:bg-eucalyptus-600 focus:text-white focus:rounded-md focus:shadow-lg focus:outline-none focus:ring-2 focus:ring-eucalyptus-500 focus:ring-offset-2"
    >
      Skip to main content
    </a>

    <!-- Header: keep out of Pagefind index (optional safety) -->
    <div data-pagefind-ignore>
      <Header currentPath={currentPath} />
    </div>

    <!-- ✅ Pagefind body scope: once this exists anywhere, other pages need it too -->
    <main
      id="main-content"
      class="pt-16 md:pt-20"
      data-pagefind-body
    >
      <slot />
    </main>

    <!-- Footer: keep out of Pagefind index (optional safety) -->
    <div data-pagefind-ignore>
      <Footer lang={lang} />
    </div>
    <!-- AI Chat Drawer (Global) -->
    <ChatDrawer />
    <CookieConsent />
  </body>
</html>