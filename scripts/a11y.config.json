{
    "includeGlobs": [
        "src/**/*.{astro,md,mdx,html}",
        "src/components/**/*.{astro,jsx,tsx}"
    ],
    "excludeGlobs": [
        "**/node_modules/**",
        "**/dist/**",
        "**/.agent/**"
    ],
    "distGlobs": [
        "dist/**/*.html"
    ],
    "distExcludeGlobs": [
        "dist/404.html",
        "dist/test/**/*.html",
        "dist/**/design-system-test/**/*.html"
    ],
    "rules": {
        "source": {
            "img-alt": {
                "severity": "error"
            },
            "button-name": {
                "severity": "error"
            },
            "link-name": {
                "severity": "error"
            },
            "interactive-handlers": {
                "severity": "warning"
            }
        },
        "dist": {
            "html-lang": {
                "severity": "error"
            },
            "main-landmark": {
                "severity": "error"
            },
            "unique-h1": {
                "severity": "error"
            },
            "heading-order": {
                "severity": "warning"
            },
            "unique-ids": {
                "severity": "error"
            }
        }
    },
    "allowlists": {
        "img-alt": [
            {
                "file": "src/components/Header.astro",
                "reason": "Decorative logo handled via aria-hidden separately"
            }
        ],
        "interactive-handlers": [
            {
                "regex": ".*Click.*",
                "file": "src/components/interactive/.*",
                "reason": "Custom widget logic"
            }
        ],
        "unique-h1": [
            {
                "file": "dist/blog/index.html",
                "reason": "Blog list might have multiple article titles as H1s? No, usually H2. checking..."
            }
        ]
    },
    "axe": {
        "routes": [
            "/",
            "/about",
            "/experience",
            "/projects",
            "/blog"
        ],
        "thresholds": {
            "critical": 0,
            "serious": 0,
            "moderate": 5,
            "minor": 10
        }
    }
}