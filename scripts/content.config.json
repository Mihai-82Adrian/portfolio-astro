{
    "includeGlobs": [
        "src/content/**/*.{md,mdx}",
        "src/pages/**/*.{md,mdx,astro}"
    ],
    "excludeGlobs": [
        "dist/**",
        ".astro/**",
        "node_modules/**",
        ".agent/**",
        "docs/**",
        "src/pages/test/**",
        "src/pages/**/design-system-test.astro"
    ],
    "languagePolicy": {
        "blog": "en",
        "pages": [
            "de",
            "en",
            "ro"
        ]
    },
    "rules": {
        "requireExecutiveSummary": {
            "severity": "error",
            "message": "Content must start with an executive summary / BLUF (Bottom Line Up Front)."
        },
        "requireOutlineFirst": {
            "severity": "warning",
            "message": "Long content should have an outline or table of contents early on."
        },
        "bannedWords": {
            "severity": "warning",
            "words": [
                "delve",
                "tapestry",
                "leverage",
                "utilize",
                "synergy",
                "paradigm shift"
            ]
        },
        "requireDeepDiveElements": {
            "severity": "warning",
            "message": "Deep dive content should include at least one code block or diagram.",
            "requiredElements": [
                "code_block",
                "mermaid_diagram"
            ]
        },
        "requireCitations": {
            "severity": "warning",
            "message": "Statistical claims or specific facts should be cited."
        },
        "frontmatterRequiredFields": {
            "severity": "error",
            "fields": [
                "title",
                "description",
                "pubDate",
                "tags",
                "lang"
            ]
        }
    }
}