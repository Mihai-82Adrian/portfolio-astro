{
    "includeGlobs": [
        "src/**/*.{astro,ts,tsx,js,jsx,md,mdx,css}"
    ],
    "excludeGlobs": [
        "dist/**",
        ".astro/**",
        "node_modules/**",
        ".agent/**",
        "docs/**",
        "src/pages/test/**",
        "src/pages/**/design-system-test.astro"
    ],
    "allowedFilesWithHex": [
        "tailwind.config.mjs",
        ".agent/**/design-tokens.json",
        "src/styles/**",
        "src/utils/github.ts"
    ],
    "rules": {
        "noHardcodedHex": {
            "severity": "error",
            "suggestToken": true
        },
        "noInlineStyleHex": {
            "severity": "error"
        },
        "noArbitraryValues": {
            "severity": "warning",
            "allow": [
                "^bg-\\[url\\(.+\\)\\]$",
                "^content-\\[.*\\]$",
                "^grid-cols-\\[.*\\]$"
            ]
        },
        "noArbitraryZIndex": {
            "severity": "warning",
            "allow": [
                "z-0",
                "z-10",
                "z-20",
                "z-30",
                "z-40",
                "z-50"
            ]
        },
        "bannedSpacingScale": {
            "severity": "warning",
            "ban": [
                "7"
            ]
        },
        "disallowNonSystemColors": {
            "severity": "warning"
        }
    }
}