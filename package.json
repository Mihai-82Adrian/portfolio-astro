    "autoprefixer": "^10.4.21",
    "baseline-browser-mapping": "^2.9.19",
    "glob": "^13.0.3",
    "gray-matter": "^4.0.3",
    "pagefind": "^1.4.0",
    "patch-package": "^8.0.1",
    "rehype-katex": "^7.0.1",
