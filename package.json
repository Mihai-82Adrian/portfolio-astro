    "lint:design-system:json": "node .agent/skills/design-system-guardian/scripts/audit-styles.js --json",
    "lint:content": "node .agent/skills/content-architect/scripts/audit-content.mjs",
    "export:corpus": "node .agent/skills/content-architect/scripts/export-corpus.mjs",
